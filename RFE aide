    def btn_verifier_tva(self):
        """
        Contrôle les N° TVA calculés des tiers cochés via l'API VIES
        (https://ec.europa.eu/taxation_customs/vies/).
        Met à jour la colonne 'Ctrl TVA' avec ✅ Valide / ❌ Invalide / ⚠ Inconnu.
        """
        if not self.data:
            messagebox.showwarning("Vérification TVA", "Aucune donnée chargée."); return
        if self._running:
            messagebox.showwarning("Vérification TVA", "Traitement en cours."); return

        todo = [r for r in self.data
                if r.get("checked") and r.get("tva_calcule","").startswith("FR")]
        if not todo:
            messagebox.showwarning("Vérification TVA",
                "Aucun tiers coché avec un N° TVA FR.\nCalculez d'abord les N° TVA."); return

        if not messagebox.askyesno("Contrôle VIES",
                f"Vérifier {len(todo)} N° TVA via VIES ?"):
            return

        self._running = True
        threading.Thread(target=self._vies_thread, args=(todo,), daemon=True).start()

    def _vies_thread(self, records):
        """Interroge l'API VIES pour chaque N° TVA, avec parallélisme modéré."""
        import concurrent.futures, threading as _th

        n = len(records)
        self._prog(0, f"0 / {n}")
        done_count = [0]
        lock = _th.Lock()
        sem  = _th.Semaphore(3)   # max 3 requêtes simultanées — VIES est sensible

        import xml.etree.ElementTree as ET

        def _vies_check(country, vat_num):
            """Retourne True/False/None (None = service indisponible)."""
            soap = (
                '<?xml version="1.0" encoding="UTF-8"?>'
                '<soapenv:Envelope '
                ' xmlns:soapenv="http://schemas.xmlsoap.org/soap/envelope/" '
                ' xmlns:urn="urn:ec.europa.eu:taxud:vies:services:checkVat:types">'
                '<soapenv:Body><urn:checkVat>'
                f'<urn:countryCode>{country}</urn:countryCode>'
                f'<urn:vatNumber>{vat_num}</urn:vatNumber>'
                '</urn:checkVat></soapenv:Body></soapenv:Envelope>'
            )
            try:
                resp = requests.post(
                    "https://ec.europa.eu/taxation_customs/vies/services/checkVatService",
                    data=soap.encode("utf-8"),
                    headers={"Content-Type": "text/xml; charset=utf-8", "SOAPAction": ""},
                    timeout=15)
                if resp.status_code == 200:
                    root = ET.fromstring(resp.text)
                    ns = root.find(".//{urn:ec.europa.eu:taxud:vies:services:checkVat:types}valid")
                    plain = root.find(".//valid")
                    el = ns if ns is not None else plain
                    if el is not None:
                        return el.text.strip().lower() == "true"
                return None  # SOAP Fault ou code inattendu
            except Exception:
                return None

        def _sirene_check(siren):
            """Retourne True si le SIREN existe et est actif, False si inexistant, None si erreur."""
            try:
                resp = requests.get(
                    "https://recherche-entreprises.api.gouv.fr/search",
                    params={"q": siren, "per_page": "5"},
                    timeout=8)
                if resp.status_code != 200:
                    return None
                for r in resp.json().get("results", []):
                    if r.get("siren") == siren:
                        etat = str(r.get("etat_administratif") or "").upper()
                        return etat != "C"   # C = Cessé
                return False  # SIREN absent du registre
            except Exception:
                return None

        def _check(rec):
            tva = rec.get("tva_calcule", "")
            if not tva.startswith("FR") or len(tva) != 13:
                rec["tva_statut"] = "Format ?"
                return

            country = tva[:2]   # "FR"
            vat_num = tva[2:]   # 11 chiffres (clé 2 + SIREN 9)
            siren   = tva[4:]   # 9 derniers = SIREN

            with sem:
                # ── 1. VIES SOAP ──────────────────────────────────
                vies = _vies_check(country, vat_num)

                if vies is True:
                    rec["tva_statut"] = "OK"
                    time.sleep(0.4)
                    return

                # ── 2. Fallback SIRENE si VIES négatif ou indispo ─
                # VIES ne recense pas toutes les entreprises FR
                # (auto-entrepreneurs, petites PME non assujetties intracom)
                sirene = _sirene_check(siren)

                if sirene is True:
                    # SIREN actif → N° TVA mathématiquement valide
                    src = "VIES+SIRENE" if vies is False else "SIRENE"
                    rec["tva_statut"] = f"OK ({src})"
                elif sirene is False:
                    rec["tva_statut"] = "Non trouvé"
                else:
                    # Les deux sources indisponibles
                    rec["tva_statut"] = "Indéterminé"

                time.sleep(0.4)

            with lock:
                done_count[0] += 1
                pct = done_count[0] / n * 100
                self._prog(pct, f"{done_count[0]} / {n} — contrôle VIES…")

        with concurrent.futures.ThreadPoolExecutor(max_workers=3) as pool:
            futures = [pool.submit(_check, rec) for rec in records]
            concurrent.futures.wait(futures)

        self._running = False

        # Bilan
        ok_count    = sum(1 for r in records if r.get("tva_statut") == "OK")
        ko_count    = sum(1 for r in records if r.get("tva_statut") == "Non trouvé")
        err_count   = n - ok_count - ko_count

        self.root.after(0, self.refresh_table)
        self._prog(100, "Terminé")

        err_note = f" / {err_count} erreur(s)" if err_count else ""
        msg = f"VIES : {ok_count} OK  |  {ko_count} non trouvé{err_note}"
        self.root.after(0, lambda m=msg: messagebox.showinfo("Contrôle TVA", m))
        self._status(f"Contrôle VIES : {ok_count} OK, {ko_count} non trouvé(s)"
                     + (f", {err_count} erreur(s)" if err_count else ""))

