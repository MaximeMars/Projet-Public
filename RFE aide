                            {k:rec[k] for k in ("intitule","adresse","complement","ville","code_postal")})
                    else: self.data.append(rec)
            else: self.data = records
        else:
            self.data = records

        self.lbl_count.config(text=f"{len(self.data)} tiers chargés")
        self.refresh_table()
        messagebox.showinfo("Import", f"{len(records)} tiers chargés.")

    def _parse_file(self, path):
        ext = os.path.splitext(path)[1].lower()
        records = []
        if ext == ".csv":
            with open(path,"r",encoding="utf-8-sig",errors="replace") as f:
                sample = f.read(8192); f.seek(0)
                sep = ";" if sample.count(";") >= sample.count(",") else ","
                for row in csv.DictReader(f, delimiter=sep):
                    records.append(csv_row_to_record(row))
        elif ext in (".xlsx",".xls"):
            if HAS_PANDAS:
                for _, row in pd.read_excel(path, dtype=str).fillna("").iterrows():
                    records.append(csv_row_to_record(dict(row)))
            elif HAS_OPENPYXL:
                import openpyxl as xl
                wb = xl.load_workbook(path, data_only=True); ws = wb.active
                hdrs = [str(c.value or "").strip() for c in next(ws.iter_rows(max_row=1))]
                for row in ws.iter_rows(min_row=2, values_only=True):
                    records.append(csv_row_to_record(
                        dict(zip(hdrs,[str(v or "").strip() for v in row]))))
            else:
                raise RuntimeError("pandas ou openpyxl requis.\npip install openpyxl")
        else:
            raise ValueError(f"Format non supporté : {ext}")
        return records

