class ModernButton(tk.Canvas):
    """Bouton arrondi dessiné sur Canvas."""
    def __init__(self, parent, text, command=None,
                 bg=C_ACCENT, fg="white", hover=None,
                 radius=8, font=("Segoe UI",9,"bold"),
                 width=160, height=36, **kwargs):
        super().__init__(parent, width=width, height=height,
                         highlightthickness=0, bg=parent.cget("bg"), **kwargs)
        self._bg      = bg
        self._hover   = hover or self._darken(bg)
        self._fg      = fg
        self._text    = text
        self._command = command
        self._radius  = radius
        self._font    = font
        self._w       = width
        self._h       = height
        self._pressed = False
        self._draw(bg)
        self.bind("<Enter>",          lambda e: self._draw(self._hover))
        self.bind("<Leave>",          lambda e: self._draw(self._bg))
        self.bind("<ButtonPress-1>",  lambda e: self._on_press())
        self.bind("<ButtonRelease-1>",lambda e: self._on_release())

    def _darken(self, hex_color):
        hex_color = hex_color.lstrip("#")
        r,g,b = int(hex_color[0:2],16), int(hex_color[2:4],16), int(hex_color[4:6],16)
        r,g,b = max(0,r-25), max(0,g-25), max(0,b-25)
        return f"#{r:02x}{g:02x}{b:02x}"

    def _draw(self, color):
        self.delete("all")
        r, w, h = self._radius, self._w, self._h
        self.create_arc(0,0,r*2,r*2, start=90, extent=90, fill=color, outline=color)
        self.create_arc(w-r*2,0,w,r*2, start=0, extent=90, fill=color, outline=color)
        self.create_arc(0,h-r*2,r*2,h, start=180, extent=90, fill=color, outline=color)
        self.create_arc(w-r*2,h-r*2,w,h, start=270, extent=90, fill=color, outline=color)
        self.create_rectangle(r,0,w-r,h, fill=color, outline=color)
        self.create_rectangle(0,r,w,h-r, fill=color, outline=color)
        self.create_text(w//2, h//2, text=self._text,
                         fill=self._fg, font=self._font)

    def _on_press(self):
        self._pressed = True
        self._draw(self._darken(self._hover))

    def _on_release(self):
        if self._pressed and self._command:
            self._command()
        self._pressed = False
        self._draw(self._hover)

    def config_text(self, text):
        self._text = text
        self._draw(self._bg)


class SidebarButton(tk.Frame):
    """Bouton de la sidebar avec icône + label."""
    def __init__(self, parent, letter, label, command, is_active=False):
        super().__init__(parent, bg=SB_ACTIVE if is_active else SB_BG,
                         cursor="hand2")
        self._cmd      = command
        self._active   = is_active
        self._normal   = SB_ACTIVE if is_active else SB_BG
        self._lbl_text = label

        inner = tk.Frame(self, bg=self["bg"])
        inner.pack(fill=tk.X, padx=12, pady=6)

        badge = tk.Label(inner, text=letter, width=2,
                         bg=SB_ACTIVE if is_active else SB_HOVER,
                         fg=SB_TEXT_A,
                         font=("Segoe UI", 9, "bold"),
                         relief="flat")
        badge.pack(side=tk.LEFT, padx=(0,8))

        lbl = tk.Label(inner, text=label,
                       bg=self["bg"],
                       fg=SB_TEXT_A if is_active else SB_TEXT,
                       font=("Segoe UI", 9),
                       anchor="w")
        lbl.pack(side=tk.LEFT, fill=tk.X)

        for w in [self, inner, badge, lbl]:
            w.bind("<Button-1>", lambda e: self._cmd())
            w.bind("<Enter>", self._on_enter)
            w.bind("<Leave>", self._on_leave)

    def _on_enter(self, e):
        if not self._active:
            for w in self.winfo_children() + [self]:
                try: w.config(bg=SB_HOVER)
                except: pass
    def _on_leave(self, e):
        if not self._active:
            for w in self.winfo_children() + [self]:
                try: w.config(bg=SB_BG)
                except: pass


