    def _selected_recs(self):
        """Retourne les enregistrements correspondant à la sélection Treeview."""
        return [r for iid in self.tree.selection()
                for r in [self._iid_to_rec(iid)] if r]

    def _check_selection(self, state: bool):
        """Coche ou décoche tous les enregistrements sélectionnés."""
        recs = self._selected_recs()
        if not recs:
            # Si rien de sélectionné, applique sur les lignes visibles
            recs = self._get_visible()
        for rec in recs:
            rec["checked"] = state
        self.refresh_table()
        n = len(recs)
        self._status(f"{'Cochés' if state else 'Décochés'} : {n} tiers")

    def _on_selection_change(self, event=None):
        """Met à jour le compteur de sélection."""
        if self._sel_label is None: return
        n = len(self.tree.selection())
        if n:
            self._sel_label.config(text=f"{n} ligne(s) sélectionnée(s)")
        else:
            self._sel_label.config(text="")

    def _select_all_visible(self, event=None):
        """Ctrl+A : sélectionne toutes les lignes visibles (comme Excel)."""
        iids = self.tree.get_children()
        if iids:
            self.tree.selection_set(iids)
        return "break"



    # Colonnes adresse sur lesquelles l'éditeur flottant est actif
    _EDITABLE_COLS = {"adr", "cpl", "vil", "adr_t", "vil_t"}

    def _on_combined_click(self, event):
        """Dispatch : colonne ☑ → cochage  |  colonne adresse → éditeur texte."""
        self._on_click(event)
        if self.tree.identify_region(event.x, event.y) == "cell":
            col_pos = self.tree.identify_column(event.x)
            if col_pos == "#1":
                return
            dc = self.tree["displaycolumns"]
            if dc in (("all",), "all"):
                dc = [c[0] for c in COLUMNS]
            idx = int(col_pos[1:]) - 1
            if 0 <= idx < len(dc) and dc[idx] in self._EDITABLE_COLS:
                self._show_cell_editor(event)

