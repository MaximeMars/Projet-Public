class RoundBtn(tk.Canvas):
    def __init__(self, parent, text, cmd=None,
                 bg=C_ACCENT, fg="white",
                 r=6, w=160, h=32,
                 font=(FONT_UI, 12, "bold"), **kw):
        super().__init__(parent, width=w, height=h,
                         highlightthickness=0,
                         bd=0, bg=parent.cget("bg"), **kw)
        self._bg=bg; self._hov=self._dark(bg); self._fg=fg
        self._txt=text; self._cmd=cmd; self._r=r
        self._w=w; self._h=h; self._font=font
        self._enabled = True
        self._draw(bg)
        self.bind("<Enter>",           lambda e: self._on_enter())
        self.bind("<Leave>",           lambda e: self._on_leave())
        self.bind("<ButtonPress-1>",   lambda e: self._on_press())
        self.bind("<ButtonRelease-1>", lambda e: self._on_release())

    def _on_enter(self):
        if self._enabled: self._draw(self._hov)

    def _on_leave(self):
        if self._enabled: self._draw(self._bg)

    def _on_press(self):
        if self._enabled: self._draw(self._dark(self._hov))

    def _on_release(self):
        if self._enabled:
            self._draw(self._hov)
            if self._cmd: self._cmd()

    def _dark(self, c):
        c=c.lstrip("#"); r,g,b=int(c[:2],16),int(c[2:4],16),int(c[4:],16)
        return f"#{max(0,r-22):02x}{max(0,g-22):02x}{max(0,b-22):02x}"

    def _draw(self, c):
        self.delete("all")
        r,w,h=self._r,self._w,self._h
        for x,y,s,e in [(0,0,90,90),(w-2*r,0,0,90),(0,h-2*r,180,90),(w-2*r,h-2*r,270,90)]:
            self.create_arc(x,y,x+2*r,y+2*r,start=s,extent=e,fill=c,outline=c)
        self.create_rectangle(r,0,w-r,h,fill=c,outline=c)
        self.create_rectangle(0,r,w,h-r,fill=c,outline=c)
        self.create_text(w//2,h//2,text=self._txt,fill=self._fg,font=self._font)

    def set_text(self, t): self._txt=t; self._draw(self._bg)

    def set_enabled(self, enabled):
        """Active ou désactive visuellement le bouton."""
        self._enabled = enabled
        disabled_color = "#a0aec0"
        if enabled:
            self._draw(self._bg)
            self.config(cursor="hand2")
        else:
            self._draw(disabled_color)
            self.config(cursor="")


