    def _backup_f_comptet(self, dest_path):
        """Exporte F_COMPTET en CSV vers dest_path (.bak) avant la mise à jour."""
        try:
            cursor = self.db_conn.cursor()
            cursor.execute("""
                SELECT CT_Num, CT_Intitule, CT_Adresse, CT_Complement,
                       CT_Ville, CT_CodePostal, CT_Siret, CT_Identifiant
                FROM F_COMPTET ORDER BY CT_Num""")
            rows = cursor.fetchall()
            cols = [d[0] for d in cursor.description]
            with open(dest_path, "w", newline="", encoding="utf-8-sig") as f:
                import csv as _csv
                w = _csv.writer(f, delimiter=";")
                w.writerow(cols)
                w.writerows([[str(v or "") for v in row] for row in rows])
            self.root.after(0, lambda: messagebox.showinfo(
                "Sauvegarde",
                "Sauvegarde effectuee (" + str(len(rows)) + " lignes).\n" + str(dest_path)))
        except Exception as e:
            self.root.after(0, lambda err=str(e): messagebox.showwarning(
                "Sauvegarde échouée",
                "La sauvegarde n'a pas pu etre creee :\n" + err +
                "\n\nLa mise a jour va continuer quand meme."))

    def _update_thread(self, records):
        n       = len(records)
        errors  = []   # liste des (code_sage, message)
        updated = 0
        self._prog(0, f"0 / {n}")

        try:
            cursor = self.db_conn.cursor()

            for i, rec in enumerate(records):
                code = rec.get("code_sage", "?")
                try:
                    siren_t    = str(rec.get("siren_trouve", "")).strip()
                    siret_t    = str(rec.get("siret_trouve", "")).strip()
                    siret_base = str(rec.get("siren_base",   "")).strip()

                    # ── Reconstruction du SIRET ───────────────────────────
                    # Priorité : siret_trouve (14 chiffres) > siret_base > siren seul
                    if siret_t and siret_t.isdigit() and len(siret_t) == 14:
                        siret_write = siret_t             # SIRET SIRENE (meilleure source)
                    elif (len(siret_base) == 14 and siret_base.isdigit()
                            and siret_base[:9] == siren_t):
                        siret_write = siret_base          # SIRET original conservé
                    else:
                        siret_write = siren_t             # SIREN seul (9 chiffres)

                    # ── Troncature selon longueurs max F_COMPTET (PDF) ───
                    def trunc(val, maxlen):
                        return str(val or "").strip()[:maxlen]

                    pairs = [
                        ("CT_Siret",       trunc(siret_write,                                    14)),
                        ("CT_Identifiant", trunc(rec.get("tva_calcule",    ""),                  25)),
                        ("CT_Adresse",     trunc(rec.get("adresse_trouvee",""),                  35)),
                        ("CT_CodePostal",  trunc(rec.get("cp_trouve",      ""),                   9)),
                        ("CT_Ville",       trunc(rec.get("ville_trouvee",  "").title(),           35)),
                    ]

                    sets, params = [], []
                    for col, val in pairs:
                        if val:                          # ne pas écraser avec vide
                            sets.append(f"{col} = ?")
                            params.append(val)

                    if sets:
                        params.append(code)
                        cursor.execute(
                            f"UPDATE F_COMPTET SET {', '.join(sets)} "
                            f"WHERE CT_Num = ?",
                            params)
                        updated += 1

                except Exception as ex:
                    errors.append((code, str(ex)))

                self._prog((i + 1) / n * 100, f"{i+1} / {n}")
                time.sleep(0.03)

            self.db_conn.commit()

        except Exception as ex:
            # Rollback si erreur globale (ex : connexion coupée en cours)
            try: self.db_conn.rollback()
            except: pass
            self.root.after(0, lambda e=str(ex):
                messagebox.showerror("Erreur SQL critique", e))
            self._prog(0, "Annulé")
            return

        # ── Rapport final ───────────────────────────────────────
        self._prog(100, "Terminé")
        if errors:
            detail = "\n".join(f"• {c} : {m}" for c, m in errors[:10])
            if len(errors) > 10: detail += f"\n… +{len(errors)-10}"
            msg = f"{updated} mis à jour / {len(errors)} erreur(s) :\n{detail}"
            self.root.after(0, lambda m=msg: messagebox.showwarning("Mise à jour", m))
        else:
            msg = f"{updated} tiers mis à jour."
            self.root.after(0, lambda m=msg: messagebox.showinfo("Mise à jour", m))
        self._status(msg.split("\n")[0])

