    def _show_cell_editor(self, event):
        """
        Sur les colonnes adresse : affiche une Entry flottante sur la cellule,
        texte pré-sélectionné — sélectionner et copier avec Ctrl+C ou clic-glisser.
        """
        region = self.tree.identify_region(event.x, event.y)
        if region != "cell":
            return
        col = self.tree.identify_column(event.x)
        if col == "#1":
            return
        item = self.tree.identify_row(event.y)
        if not item:
            return

        col_idx  = int(col[1:]) - 1
        all_vals = self.tree.item(item, "values")
        cell_val = str(all_vals[col_idx]) if col_idx < len(all_vals) else ""

        tree_x = self.tree.winfo_rootx()
        tree_y = self.tree.winfo_rooty()
        bbox   = self.tree.bbox(item, col)
        if not bbox:
            return
        bx, by, bw, bh = bbox
        abs_x = tree_x + bx
        abs_y = tree_y + by

        if hasattr(self, "_cell_editor") and self._cell_editor:
            try: self._cell_editor.destroy()
            except Exception: pass
            self._cell_editor = None

        popup = tk.Toplevel(self.root)
        popup.overrideredirect(True)
        popup.geometry(f"{bw}x{bh}+{abs_x}+{abs_y}")
        popup.configure(bg=C_WHITE)
        popup.attributes("-topmost", True)

        var   = tk.StringVar(value=cell_val)
        entry = tk.Entry(popup,
                         textvariable=var,
                         font=(FONT_UI, 11),
                         bg="#eef4ff", fg=C_TEXT,
                         relief="flat", bd=1,
                         selectbackground="#bfdbfe",
                         selectforeground=C_TEXT)
        entry.pack(fill=tk.BOTH, expand=True)
        entry.select_range(0, tk.END)
        entry.focus_set()

        self._cell_editor = popup

        def _close(e=None):
            try: popup.destroy()
            except Exception: pass
            self._cell_editor = None

        entry.bind("<Escape>",   _close)
        entry.bind("<Return>",   _close)
        entry.bind("<Tab>",      _close)
        entry.bind("<FocusOut>", lambda e: self.root.after(100, _close))
        entry.bind("<Key>", lambda e: "break" if e.keysym not in
                   ("c","C","a","A","Left","Right","Home","End",
                    "Shift_L","Shift_R","Control_L","Control_R") else None)

    def _on_click(self, event):
        if self.tree.identify_region(event.x, event.y) != "cell": return
        item = self.tree.identify_row(event.y)
        if not item: return

        if self.tree.identify_column(event.x) == "#1":
            # Clic sur la colonne ☑ : bascule tous les sélectionnés (ou juste cette ligne)
            sel = self.tree.selection()
            targets = list(sel) if item in sel and len(sel) > 1 else [item]
            # Décider de l'état cible : si tous cochés → décocher, sinon cocher
            recs_targets = [self._iid_to_rec(i) for i in targets if self._iid_to_rec(i)]
            new_state = not all(r.get("checked") for r in recs_targets)
            for rec in recs_targets:
                rec["checked"] = new_state
            self.refresh_table()

    def _on_space(self, event):
        """Espace : bascule le cochage de la sélection courante."""
        recs = self._selected_recs()
        if not recs: return
        new_state = not all(r.get("checked") for r in recs)
        for rec in recs:
            rec["checked"] = new_state
        self.refresh_table()
        return "break"   # empêche le scroll par défaut

    def _on_right_click(self, event):
        """Menu contextuel clic-droit sur la table."""
        item = self.tree.identify_row(event.y)
        if not item: return

        # Si la ligne cliquée n'est pas dans la sélection, on la sélectionne seule
        if item not in self.tree.selection():
            self.tree.selection_set(item)

        n_sel = len(self.tree.selection())
        menu = tk.Menu(self.root, tearoff=0,
                       bg=C_WHITE, fg=C_TEXT,
                       activebackground="#dbeafe",
                       activeforeground=C_TEXT,
                       font=(FONT_UI, 11),
                       bd=0, relief="flat")
        menu.add_command(
            label=f"☑  Cocher  ({n_sel} ligne{'s' if n_sel > 1 else ''})",
            command=lambda: self._check_selection(True))
        menu.add_command(
            label=f"☐  Décocher  ({n_sel} ligne{'s' if n_sel > 1 else ''})",
            command=lambda: self._check_selection(False))
        menu.add_separator()
        menu.add_command(label="☑  Tout cocher (visible)",   command=self.check_all)
        menu.add_command(label="☐  Tout décocher (visible)", command=self.uncheck_all)
        menu.add_separator()

        # Raccourcis info
        rec = self._iid_to_rec(item)
        if rec and rec.get("suggestions"):
            menu.add_command(
                label="💡  Voir les suggestions…",
                command=lambda: self._show_suggestions_popup(rec, rec["suggestions"]))
        else:
            menu.add_command(label="💡  Pas de suggestions disponibles", state="disabled")

        menu.tk_popup(event.x_root, event.y_root)

    def _on_double_click(self, event):
        item = self.tree.identify_row(event.y)
        if not item: return
        rec = next((r for r in self.data
                    if (r.get("code_sage") or str(id(r))) == item), None)
        if not rec: return
        suggestions = rec.get("suggestions", [])
        # Ouvre le popup même sans suggestions (affiche un message informatif)
        self._show_suggestions_popup(rec, suggestions)

