    def _status(self, msg):
        self.root.after(0, lambda: self.var_status.set(msg))

    def _prog(self, pct, label=""):
        def _do():
            self.var_prog.set(pct)
            self.lbl_prog.config(text=label)
        self.root.after(0, _do)

    def _ensure_openpyxl(self):
        if HAS_OPENPYXL: return True
        if messagebox.askyesno("openpyxl manquant","Installer openpyxl ?"):
            if install_package("openpyxl"):
                messagebox.showinfo("Succès","Redémarrez l'application.")
            else:
                messagebox.showerror("Erreur","pip install openpyxl")
        return False


