    def _appdata_writable(self):
        """Vérifie que %APPDATA%/AideRFE est accessible en écriture."""
        try:
            base = os.environ.get("APPDATA") or os.path.expanduser("~")
            folder = os.path.join(base, "AideRFE")
            os.makedirs(folder, exist_ok=True)
            probe = os.path.join(folder, ".write_test")
            with open(probe, "w") as f: f.write("ok")
            os.remove(probe)
            return True, folder
        except Exception as e:
            return False, str(e)

    def _ini_path(self):
        base = os.environ.get("APPDATA") or os.path.expanduser("~")
        return os.path.join(base, "AideRFE", "config.ini")

    def _json_path(self):
        if self._json_cfg_path_override:
            return self._json_cfg_path_override
        # Fallback : même dossier que le script
        return os.path.join(os.path.dirname(os.path.abspath(
            getattr(__import__("__main__"), "__file__", sys.argv[0])
        )), "aiderfe_config.json")

    # ── Lecture ───────────────────────────────────────────

    def _load_cfg(self):
        """
        Charge depuis INI (%APPDATA%) en priorité,
        puis depuis JSON si l'INI est absent ou illisible.
        """
        defaults = {
            "server": "localhost", "database": "", "username": "",
            "win_auth": True, "remember": True,
            "cfg_mode": "ini",          # "ini" ou "json"
            "json_path": "",            # chemin JSON personnalisé
        }

        # ── Essai INI ────────────────────────────────────
        ini = self._ini_path()
        if os.path.exists(ini):
            try:
                cfg = configparser.ConfigParser()
                cfg.read(ini, encoding="utf-8")
                sect = cfg["connexion"] if cfg.has_section("connexion") else {}
                return {
                    "server":   sect.get("server",   "localhost"),
                    "database": sect.get("database", ""),
                    "username": sect.get("username", ""),
                    "win_auth": sect.get("win_auth", "true").lower() == "true",
                    "remember": sect.get("remember", "true").lower() == "true",
                    "cfg_mode": sect.get("cfg_mode", "ini"),
                    "json_path": sect.get("json_path", ""),
                }
            except Exception:
                pass

        # ── Essai JSON ───────────────────────────────────
        for jpath in filter(None, [self._json_cfg_path_override, self._json_path()]):
            if os.path.exists(jpath):
                try:
                    with open(jpath, "r", encoding="utf-8") as f:
                        data = json.load(f)
                    defaults.update(data)
                    defaults["cfg_mode"] = "json"
                    defaults["json_path"] = jpath
                    if self._json_cfg_path_override is None:
                        self._json_cfg_path_override = jpath
                    return defaults
                except Exception:
                    pass

        return defaults

    # ── Écriture ─────────────────────────────────────────

    def _save_cfg(self, cfg_dict, mode=None, json_path=None):
        """
        mode = "ini"  -> ecrit dans %APPDATA%/AideRFE/config.ini
        mode = "json" -> ecrit dans json_path (ou chemin par defaut)
        Si mode=None  -> utilise cfg_dict["cfg_mode"] ou "ini".
        """
        if mode is None:
            mode = cfg_dict.get("cfg_mode", "ini")
        payload = {
            "server":   cfg_dict.get("server",   ""),
            "database": cfg_dict.get("database", ""),
            "username": cfg_dict.get("username", ""),
            "win_auth": cfg_dict.get("win_auth", True),
            "remember": True,
            "cfg_mode": mode,
        }

        if mode == "json":
            dest = json_path or self._json_cfg_path_override or self._json_path()
            payload["json_path"] = dest
            try:
                with open(dest, "w", encoding="utf-8") as f:
                    json.dump(payload, f, indent=2, ensure_ascii=False)
                self._json_cfg_path_override = dest
                return True, dest
            except Exception as e:
                return False, str(e)
        else:
            # mode INI
            writable, info = self._appdata_writable()
            if not writable:
                return False, info
            cfg = configparser.ConfigParser()
            cfg["connexion"] = {k: str(v) for k, v in payload.items()}
            try:
                with open(self._ini_path(), "w", encoding="utf-8") as f:
                    cfg.write(f)
                return True, self._ini_path()
            except Exception as e:
                return False, str(e)

    def _clear_cfg(self):
        """Supprime INI et JSON s'ils existent."""
        for p in [self._ini_path(),
                  self._json_cfg_path_override,
                  self._json_path()]:
            try:
                if p and os.path.exists(p):
                    os.remove(p)
            except Exception:
                pass
        self._json_cfg_path_override = None

