                "SIREN (base)","TVA (base)","SIREN trouvé","TVA calculé",
                "Adresse trouvée","CP trouvé","Ville trouvée","Score"]
        KEYS = ["code_sage","intitule","adresse","complement","ville","code_postal",
                "siren_base","tva_base","siren_trouve","tva_calcule",
                "adresse_trouvee","cp_trouve","ville_trouvee","score"]
        rows = [[r.get(k,"") for k in KEYS] for r in self.data]
        if path.lower().endswith(".xlsx"):
            if not self._ensure_openpyxl(): return
            import openpyxl as xl; from openpyxl.styles import PatternFill, Font
            wb = xl.Workbook(); ws = wb.active; ws.title = "Résultats SIRENE"
            ws.append(HDRS)
            for cell in ws[1]:
                cell.font = Font(bold=True, color="FFFFFF")
                cell.fill = PatternFill("solid", fgColor="1E2A3A")
            CXLS = {"100":"DCFCE7","70":"FEF3C7","50":"FEE2E2"}
            for row_data, rec in zip(rows, self.data):
                ws.append(row_data)
                sc = rec.get("score","")
                if sc in CXLS:
                    fill = PatternFill("solid", fgColor=CXLS[sc])
                    for c in ws[ws.max_row]: c.fill = fill
            for col in ws.iter_cols():
                mx = max((len(str(c.value or "")) for c in col), default=8)
                ws.column_dimensions[col[0].column_letter].width = min(mx+2, 40)
            wb.save(path)
        else:
            with open(path,"w",newline="",encoding="utf-8-sig") as f:
                w = csv.writer(f, delimiter=";")
                w.writerow(HDRS); w.writerows(rows)
        messagebox.showinfo("Export", f"Résultats exportés :\n{path}")

    # ════════════════════════════════════════════════════════
    #  HELPERS
    # ════════════════════════════════════════════════════════

    def _status(self, msg):
        self.root.after(0, lambda: self.var_status.set(msg))

    def _prog(self, pct, label=""):
        def _do():
            self.var_prog.set(pct)
            self.lbl_prog.config(text=label)
        self.root.after(0, _do)

    def _ensure_openpyxl(self):
        if HAS_OPENPYXL: return True
        if messagebox.askyesno("openpyxl manquant",
                "Installer openpyxl pour les fichiers Excel ?"):
            if install_package("openpyxl"):
                messagebox.showinfo("Succès","openpyxl installé. Redémarrez.")
            else:
                messagebox.showerror("Erreur","pip install openpyxl")
        return False


