    def _import(self):
        path = filedialog.askopenfilename(
            title="Importer un fichier Excel",
            filetypes=[("Excel","*.xlsx *.xls"),("Tous","*.*")])
        if not path:
            return
        try:
            df = pd.read_excel(path, header=0, dtype=str).fillna("")
            df.columns = [str(c).strip() for c in df.columns]

            ALIASES = {
                "intitule":          ["intitulé","intitule","nom","raison sociale","libellé"],
                "adresse":           ["adresse"],
                "complement":        ["complément","complement"],
                "code_postal":       ["code postal","code_postal","cp","code postale"],
                "ville":             ["ville"],
                "siren":             ["siren"],
                "siret":             ["siret"],
                "tva":               ["n° de tva","tva","n°tva"],
                "siren_ou_siret":    ["siren ou siret ?","siren ou siret","siren_ou_siret","type id"],
                "adresse_trouvee":   ["adresse trouvée","adresse trouvee","adresse_trouvee"],
                "complement_trouve": ["complément  trouvée","complement trouvee","complement_trouve","complément trouvée"],
                "cp_trouve":         ["code postal  trouvée","code postal trouvee","cp_trouve","code postal trouvée"],
                "ville_trouvee":     ["ville trouvée","ville trouvee","ville_trouvee"],
                "siren_trouve":      ["siren trouvée","siren trouvee","siren_trouve"],
                "siret_trouve":      ["siret trouvée","siret trouvee","siret_trouve"],
            }
            raw_lower = {c.lower(): c for c in df.columns}
            col_index = {}
            for key, alist in ALIASES.items():
                for alias in alist:
                    if alias.lower() in raw_lower:
                        col_index[key] = raw_lower[alias.lower()]
                        break

            self.df        = df
            self.col_index = col_index
            self.filepath  = path
            self.results   = [None] * len(df)
            n = len(df)
            self._lbl_file.config(text=f"📄 {os.path.basename(path)}  ({n} ligne{'s' if n>1 else ''})")
            self._btn_search.config(state="normal")
            self._btn_export.config(state="disabled")
            self._lbl_total.config(text=str(n))
            self._lbl_green.config(text="0")
            self._lbl_orange.config(text="0")
            self._lbl_red.config(text="0")
            self._lbl_pend.config(text=str(n))
            self._progress["value"]   = 0
            self._progress["maximum"] = max(n, 1)
            self._status.config(text=f"Fichier chargé : {n} ligne(s) prête(s) à enrichir.")
            self._refresh_table()
        except Exception as e:
            messagebox.showerror("Erreur", f"Impossible de lire le fichier :\n{e}")

    def _gc(self, row, key):
        col = self.col_index.get(key)
        if col and col in row.index:
            return str(row[col]).strip()
        return ""

    def _row_dict(self, row):
        return {k: self._gc(row, k) for k in self.col_index}

    def _refresh_table(self):
        flt    = self._filter_var.get()
        search = normalize(self._search_var.get())
        self._tree.delete(*self._tree.get_children())
        if self.df is None:
            return

        counts = {"green":0,"orange":0,"red":0,"pending":0}

        for idx, row in self.df.iterrows():
            res      = (self.results[idx] or {}) if self.results else {}
            enriched = res.get("enriched", {})
            status   = res.get("status", "pending")
            k = status if status in counts else "pending"
            counts[k] += 1

            if flt == "Vert"       and status != "green":   continue
            if flt == "Orange"     and status != "orange":  continue
            if flt == "Rouge"      and status != "red":     continue
            if flt == "En attente" and status != "pending": continue

            intitule = self._gc(row,"intitule")
            cp_o     = self._gc(row,"code_postal")
            ville_o  = self._gc(row,"ville")
            siren_o  = self._gc(row,"siren")
            siret_o  = self._gc(row,"siret")
            mode_o   = self._gc(row,"siren_ou_siret")
            adr_t    = enriched.get("adresse_trouvee","")
            cp_t     = enriched.get("cp_trouve","")
            ville_t  = enriched.get("ville_trouvee","")
            siren_t  = enriched.get("siren_trouve","")
            siret_t  = enriched.get("siret_trouve","")

            if search:
                blob = normalize(" ".join([intitule,cp_o,ville_o,siren_o,siret_o,adr_t,ville_t]))
                if search not in blob:
                    continue

            s_lbl = {"green":"✅ Vert","orange":"🟠 Orange","red":"❌ Rouge"}.get(status,"⏳ En attente")
            tag   = status if status in ("green","orange","red") else "pending"

            self._tree.insert("","end",iid=str(idx),tags=(tag,),
                              values=(intitule,cp_o,ville_o,siren_o,siret_o,mode_o,
                                      adr_t,cp_t,ville_t,siren_t,siret_t,s_lbl))

        self._lbl_green.config(text=str(counts["green"]))
        self._lbl_orange.config(text=str(counts["orange"]))
        self._lbl_red.config(text=str(counts["red"]))
        self._lbl_pend.config(text=str(counts["pending"]))

    def _start_search(self):
        if self.df is None:
            return
        self._running = True
        self._btn_search.config(state="disabled")
        self._btn_stop.config(state="normal")
        self._btn_import.config(state="disabled")
        self._btn_export.config(state="disabled")
        self._progress["value"]   = 0
        self._progress["maximum"] = max(len(self.df),1)
        threading.Thread(target=self._worker, daemon=True).start()

    def _stop(self):
        self._running = False
        self._btn_stop.config(state="disabled")
        self._status.config(text="Recherche interrompue par l'utilisateur.")

    def _worker(self):
        for idx, row in self.df.iterrows():
            if not self._running:
                break
            if not self._gc(row,"intitule"):
                self.q.put(("result",idx,{},""))
                continue
            try:
                enriched, status = enrich_row(self._row_dict(row))
            except Exception:
                enriched, status = {}, "red"
            self.q.put(("result",idx,enriched,status))
            time.sleep(0.20)
        self.q.put(("done",None,None,None))

    def _poll_queue(self):
        try:
            while True:
                kind,idx,enriched,status = self.q.get_nowait()
                if kind == "done":
                    self._running = False
                    self._btn_search.config(state="normal")
                    self._btn_stop.config(state="disabled")
                    self._btn_import.config(state="normal")
                    self._btn_export.config(state="normal")
                    self._status.config(text="✅ Recherche terminée — Vous pouvez exporter.")
                    self._refresh_table()
                    break
                if kind == "result":
                    self.results[idx] = {"enriched":enriched,"status":status}
                    done = sum(1 for r in self.results if r is not None)
                    self._progress["value"] = done
                    intitule = self._gc(self.df.iloc[idx],"intitule")
                    pct = done / max(len(self.df),1) * 100
                    icon = {"green":"✅","orange":"🟠","red":"❌","":"⏭"}.get(status,"⏳")
                    self._lbl_progress.config(
                        text=f"{icon}  {done}/{len(self.df)}  |  {intitule[:55]}")
                    self._status.config(
                        text=f"Traitement : {pct:.0f}%  ({done}/{len(self.df)}) — {intitule[:65]}")
                    s_lbl = {"green":"✅ Vert","orange":"🟠 Orange","red":"❌ Rouge","":"⏭ Ignoré"}.get(status,"⏳")
                    tag   = status if status in ("green","orange","red") else "pending"
                    try:
                        r = self.df.iloc[idx]
                        self._tree.item(str(idx),tags=(tag,),
                            values=(self._gc(r,"intitule"),self._gc(r,"code_postal"),
                                    self._gc(r,"ville"),self._gc(r,"siren"),
                                    self._gc(r,"siret"),self._gc(r,"siren_ou_siret"),
                                    enriched.get("adresse_trouvee",""),
                                    enriched.get("cp_trouve",""),
                                    enriched.get("ville_trouvee",""),
                                    enriched.get("siren_trouve",""),
                                    enriched.get("siret_trouve",""),
                                    s_lbl))
                    except Exception:
                        pass
                    cnts = {"green":0,"orange":0,"red":0}
                    for r2 in self.results:
                        if r2 and r2.get("status") in cnts:
                            cnts[r2["status"]] += 1
                    self._lbl_green.config(text=str(cnts["green"]))
                    self._lbl_orange.config(text=str(cnts["orange"]))
                    self._lbl_red.config(text=str(cnts["red"]))
                    self._lbl_pend.config(text=str(sum(1 for r2 in self.results if r2 is None)))
        except queue.Empty:
            pass
        self.after(80, self._poll_queue)

    def _export(self):
        if self.df is None:
            return
        out = filedialog.asksaveasfilename(
            title="Enregistrer le fichier enrichi",
            defaultextension=".xlsx",
            filetypes=[("Excel","*.xlsx")])
        if not out:
            return
        try:
            df_out = self.df.copy()
            for idx, res in enumerate(self.results):
                if not res or not res.get("enriched"):
                    continue
                e = res["enriched"]
                def _s(key, val, _i=idx):
                    col = self.col_index.get(key)
                    if col and col in df_out.columns:
                        df_out.at[_i, col] = val
                _s("adresse_trouvee",   e.get("adresse_trouvee",""))
                _s("complement_trouve", e.get("complement_trouve",""))
                _s("cp_trouve",         e.get("cp_trouve",""))
                _s("ville_trouvee",     e.get("ville_trouvee",""))
                _s("siren_trouve",      e.get("siren_trouve",""))
                _s("siret_trouve",      e.get("siret_trouve",""))

            df_out.to_excel(out, index=False)

            wb = load_workbook(out)
            ws = wb.active

            fills = {
                "green":  PatternFill("solid", fgColor=FILL_GREEN),
                "orange": PatternFill("solid", fgColor=FILL_ORANGE),
                "red":    PatternFill("solid", fgColor=FILL_RED),
            }
            hdr_fill = PatternFill("solid", fgColor="1E2140")
            hdr_font = Font(bold=True, color="FFFFFF", name="Calibri", size=10)
            thin     = Side(style="thin", color="DDDDDD")
            brd      = Border(left=thin, right=thin, top=thin, bottom=thin)

            for cell in ws[1]:
                cell.fill      = hdr_fill
                cell.font      = hdr_font
                cell.alignment = Alignment(horizontal="center", vertical="center", wrap_text=True)
                cell.border    = brd
            ws.row_dimensions[1].height = 32

            for col_idx, col in enumerate(ws.columns, 1):
                max_w = max((len(str(c.value or "")) for c in col), default=8)
                ws.column_dimensions[get_column_letter(col_idx)].width = min(max(max_w+2,10),50)

            for row_idx, res in enumerate(self.results, start=2):
                fill = fills.get((res or {}).get("status",""))
                for cell in ws[row_idx]:
                    if fill:
                        cell.fill = fill
                    cell.border    = brd
                    cell.alignment = Alignment(vertical="center")

            ws.freeze_panes = "A2"
            ws.auto_filter.ref = ws.dimensions
            wb.save(out)
            messagebox.showinfo("Export réussi ✅", f"Fichier enregistré :\n{out}")
            self._status.config(text=f"✅ Export OK → {out}")
        except Exception as e:
            messagebox.showerror("Erreur export", str(e))


