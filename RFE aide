    def _get_display_data(self):
        """Retourne les données après application de tous les filtres."""
        show_all    = self.var_show_all.get()
        global_flt  = self.var_global_filter.get().lower()
        # Ignorer le placeholder
        if global_flt == "rechercher dans tous les champs…":
            global_flt = ""

        result = []
        for rec in self.data:
            # Filtre enregistrements complets
            if not show_all and self._is_complete(rec):
                continue
            # Filtre global
            if global_flt:
                all_vals = " ".join(str(v) for v in rec.values()).lower()
                if global_flt not in all_vals:
                    continue
            # Filtres par colonne
            match = True
            for key, var in self._col_filters.items():
                flt = var.get().lower().strip()
                if flt and flt not in str(rec.get(key,"")).lower():
                    match = False; break
            if match:
                result.append(rec)
        return result

    def refresh_table(self):
        if self.tree is None:
            return
        for item in self.tree.get_children():
            self.tree.delete(item)

        rows = self._get_display_data()
        for i, rec in enumerate(rows):
            score = rec.get("score","")
            if score == "100":  tag = "sc_100"
            elif score == "70": tag = "sc_70"
            elif score == "50": tag = "sc_50"
            elif score == "0" and rec.get("siren_trouve",""):
                tag = "sc_0"
            else:
                tag = "odd" if i % 2 else "even"

            chk = "☑" if rec.get("checked") else "☐"
            values = [chk,
                rec.get("code_sage",""), rec.get("intitule",""),
                rec.get("adresse",""),   rec.get("complement",""),
                rec.get("ville",""),     rec.get("code_postal",""),
                rec.get("siren_base",""),rec.get("tva_base",""),
                rec.get("siren_trouve",""),rec.get("tva_calcule",""),
                rec.get("adresse_trouvee",""),rec.get("cp_trouve",""),
                rec.get("ville_trouvee",""), score]
            iid = rec.get("code_sage") or str(id(rec))
            self.tree.insert("", tk.END, iid=iid, values=values, tags=(tag,))

        # Mettre à jour le compteur
        total = len(self.data)
        shown = len(rows)
        self._status(f"{shown} tiers affichés sur {total}")

    def _apply_filters(self):
        if self.tree is None:
            return
        self.refresh_table()

    def _clear_filters(self):
        for var in self._col_filters.values():
            var.set("")
        self.var_global_filter.set("")
        self.refresh_table()

    @staticmethod
    def _is_complete(rec):
        return all(rec.get(k) for k in
                   ("siren_base","tva_base","intitule","adresse","ville","code_postal"))

    def _on_click(self, event):
        if self.tree.identify_region(event.x, event.y) != "cell": return
        if self.tree.identify_column(event.x) != "#1": return
        item = self.tree.identify_row(event.y)
        if not item: return
        for rec in self.data:
            if (rec.get("code_sage") or str(id(rec))) == item:
                rec["checked"] = not rec.get("checked", False)
                break
        self.refresh_table()

    def check_all(self):
        show_all   = self.var_show_all.get()
        global_flt = self.var_global_filter.get().lower()
        if global_flt == "rechercher dans tous les champs…": global_flt = ""
        for rec in self._get_display_data():
            rec["checked"] = True
        self.refresh_table()

    def uncheck_all(self):
        for rec in self.data: rec["checked"] = False
        self.refresh_table()

    def _sort_by(self, col_id):
        if col_id == "chk": return
        key  = next((c[3] for c in COLUMNS if c[0] == col_id), col_id)
        rev  = self._sort_rev.get(col_id, False)
        self.data.sort(key=lambda r: str(r.get(key,"")).lower(), reverse=rev)
        self._sort_rev[col_id] = not rev

        # Mettre à jour les flèches dans les entêtes
        for cid, label, *_ in COLUMNS:
            arrow = ""
            if cid == col_id:
                arrow = " ↑" if not rev else " ↓"
            self.tree.heading(cid, text=label + arrow)
        self.refresh_table()

