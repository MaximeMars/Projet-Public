    def _on_selection_change(self, event=None):
        """Met à jour le compteur quand la sélection Treeview change."""
        n_sel   = len(self._tree.selection())
        n_total = len(self.df) if self.df is not None else 0
        self._lbl_sel.config(text=f"{n_sel}/{n_total} sélectionné(s)")

    def _on_click(self, event):
        """Clic gauche sur la cellule Statut d'une ligne suggestion → ouvre les suggestions.
        Ignoré si clic droit ou si guard actif."""
        if event.num != 1:          # ignorer clic droit / molette
            return
        region = self._tree.identify_region(event.x, event.y)
        iid    = self._tree.identify_row(event.y)
        if region != "cell" or not iid:
            return
        try:
            col_pos = int(self._tree.identify_column(event.x).replace("#", "")) - 1
        except ValueError:
            return
        if col_pos == _STATUT_IDX:
            rd = self._get_row_dict(int(iid))
            if rd["_status"] == "suggestion":
                self._sugg_guard = True
                self.after(500, self._clear_sugg_guard)
                self._open_suggestions(int(iid))
                return "break"

    def _clear_sugg_guard(self):
        self._sugg_guard = False

    def _set_sugg_guard(self):
        """Pose le guard manuellement (depuis le menu contextuel)."""
        self._sugg_guard = True
        self.after(600, self._clear_sugg_guard)

