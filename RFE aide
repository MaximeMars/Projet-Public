    # ── Export résultats ──────────────────────────────────────────────────────
    def _export(self):
        if self.df is None:
            return

        # ── Guard : obligation d'avoir des lignes sélectionnées ──────────────
        to_export = sorted(int(iid) for iid in self._tree.selection())
        if not to_export:
            messagebox.showwarning(
                "Aucune sélection",
                "Sélectionnez au moins une ligne avant d'exporter.\n\n"
                "Utilisez «Tout sélectionner» ou cliquez sur les lignes\n"
                "souhaitées (Shift+clic pour une plage, Ctrl+clic pour ajouter).")
            return

        out = filedialog.asksaveasfilename(
            title=f"Exporter {len(to_export)} ligne(s) cochée(s)",
            defaultextension=".xlsx",
            initialfile="tiers_enrichis.xlsx",
            filetypes=[("Excel", "*.xlsx")])
        if not out:
            return
        try:
            wb = Workbook(); ws = wb.active; ws.title = "Résultats"
            ws.append(EXPORT_HDR)
            brd = _xl_style_header(ws, len(EXPORT_SRC))

            for df_idx in to_export:
                if df_idx >= len(self.df):
                    continue
                df_row   = self.df.iloc[df_idx]
                res      = self.results[df_idx] or {}
                enriched = res.get("enriched", {})
                status   = res.get("status", "")
                ws.append([self._gc(df_row, k) for k in EXPORT_SRC] +
                          [enriched.get(k, "") for k in EXPORT_FIND])
                _xl_style_data_row(ws, ws.max_row, brd, _XL_FILLS.get(status))

            _xl_auto_width(ws)
            ws.freeze_panes = "A2"
            ws.auto_filter.ref = ws.dimensions
            wb.save(out)

            n_enriched = sum(
                1 for i in to_export
                if self.results[i] and self.results[i].get("status") in
                ("green", "orange", "suggestion")
            )
            messagebox.showinfo(
                "Export ✅",
                f"Fichier enregistré :\n{out}\n\n"
                f"{len(to_export)} ligne(s) exportée(s)\n"
                f"{n_enriched} enrichie(s) sur {len(to_export)}")
            self._statusbar.config(text=f"✅  Export OK → {out}")
        except Exception as e:
            messagebox.showerror("Erreur export", str(e))


