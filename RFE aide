    def _sort_by(self, col):
        rev = self._sort_state.get(col, False)
        items = [(self._tree.set(k, col), k) for k in self._tree.get_children("")]
        items.sort(reverse=rev)
        for i, (_, k) in enumerate(items):
            self._tree.move(k, "", i)
        self._sort_state[col] = not rev

