def normalize(s):
    if not s:
        return ""
    s = str(s).upper().strip()
    s = unicodedata.normalize("NFD", s)
    s = "".join(c for c in s if unicodedata.category(c) != "Mn")
    s = re.sub(r"[^A-Z0-9 ]", " ", s)
    return re.sub(r"\s+", " ", s).strip()

def token_sim(a, b):
    STOP = {"", "SAS", "SA", "SARL", "SCI", "EURL", "SNC", "SE", "SASU", "ET", "DE", "LA", "LE", "LES"}
    ta = set(normalize(a).split()) - STOP
    tb = set(normalize(b).split()) - STOP
    if not ta or not tb:
        return 0.0
    return len(ta & tb) / max(len(ta), len(tb))

def clean_cp(cp):
    if not cp:
        return ""
    return str(cp).strip().split(".")[0].zfill(5)

def clean_siren(s):
    return re.sub(r"[^0-9]", "", str(s or ""))[:9]

def clean_siret(s):
    return re.sub(r"[^0-9]", "", str(s or ""))[:14]

def api_get(params):
    try:
        r = requests.get(API_URL, params=params, headers=HEADERS, timeout=TIMEOUT)
        r.raise_for_status()
        return r.json().get("results", [])
    except Exception:
        return []

def best_etab(result, cp_cible, siret_cible=""):
    etabs = result.get("matching_etablissements") or []
    siege = result.get("siege") or {}
    if not etabs:
        etabs = [siege] if siege else []

    if siret_cible:
        for e in etabs:
            if clean_siret(e.get("siret","")) == siret_cible:
                return e

    cpn = clean_cp(cp_cible)
    if cpn:
        flt = [e for e in etabs if clean_cp(e.get("code_postal","")) == cpn]
        if flt:
            etabs = flt

    for e in etabs:
        if e.get("est_siege"):
            return e
    return etabs[0] if etabs else siege

def build_adr(etab):
    parts = [str(etab.get(k,"") or "").strip()
             for k in ("numero_voie","type_voie","libelle_voie")]
    adr = " ".join(p for p in parts if p)
    return (adr or str(etab.get("adresse","") or "")).upper()

def enrich_row(row):
    intitule  = str(row.get("intitule","") or "").strip()
    adresse_o = str(row.get("adresse","") or "").strip()
    cp_o      = clean_cp(row.get("code_postal",""))
    ville_o   = str(row.get("ville","") or "").strip()
    siren_o   = clean_siren(row.get("siren",""))
    siret_o   = clean_siret(row.get("siret",""))
    mode      = str(row.get("siren_ou_siret","") or "").lower().strip()

    if not intitule:
        return {}, ""

    candidates = []

    # 1) Par SIRET
    if siret_o and len(siret_o) == 14:
        candidates += api_get({"q": siret_o, "per_page": 5})

    # 2) Par SIREN
    if not candidates and siren_o and len(siren_o) == 9:
        candidates += api_get({"q": siren_o, "per_page": 5})

    # 3) Par nom + CP
    if not candidates:
        p = {"q": intitule, "per_page": 25}
        if cp_o:
            p["code_postal"] = cp_o
        candidates += api_get(p)

    # 4) Par nom seul si CP donné mais rien trouvé
    if not candidates and cp_o:
        candidates += api_get({"q": intitule, "per_page": 25})

    # 5) Tokens principaux
    if not candidates:
        tokens = normalize(intitule).split()
        if len(tokens) > 1:
            candidates += api_get({"q": " ".join(tokens[:3]), "per_page": 15})

    if not candidates:
        return {}, "red"

    best_score  = -999
    best_result = None
    best_etab_  = {}

    for c in candidates:
        nom = c.get("nom_complet") or c.get("nom_raison_sociale") or ""
        etab = best_etab(c, cp_o, siret_o)
        score = token_sim(intitule, nom) * 50

        c_siren = clean_siren(c.get("siren",""))
        if siren_o and c_siren:
            score += 40 if c_siren == siren_o else -10
        c_siret = clean_siret(etab.get("siret",""))
        if siret_o and c_siret:
            score += 40 if c_siret == siret_o else 0

        etab_cp = clean_cp(etab.get("code_postal",""))
        if cp_o and etab_cp:
            if etab_cp == cp_o:
                score += 35
            elif etab_cp[:3] == cp_o[:3]:
                score += 10
            elif etab_cp[:2] == cp_o[:2]:
                score += 5
            else:
                score -= 25

        etab_ville = (etab.get("libelle_commune") or etab.get("commune") or "")
        if ville_o and etab_ville:
            score += token_sim(ville_o, etab_ville) * 20

        etab_adr = build_adr(etab)
        if adresse_o and etab_adr:
            score += token_sim(adresse_o, etab_adr) * 10

        if score > best_score:
            best_score  = score
            best_result = c
            best_etab_  = etab

    if best_result is None or best_score < 8:
        return {}, "red"

    nom_t   = best_result.get("nom_complet") or best_result.get("nom_raison_sociale") or ""
    siren_t = clean_siren(best_result.get("siren",""))
    siret_t = clean_siret(best_etab_.get("siret",""))
    adr_t   = build_adr(best_etab_)
    cp_t    = clean_cp(best_etab_.get("code_postal",""))
    ville_t = (best_etab_.get("libelle_commune") or best_etab_.get("commune") or "").upper()

    if "siret" in mode:
        out_siren, out_siret = "", siret_t
    elif "siren" in mode:
        out_siren, out_siret = siren_t, ""
    else:
        out_siren, out_siret = siren_t, siret_t

    enriched = {
        "adresse_trouvee":   adr_t,
        "complement_trouve": "",
        "cp_trouve":         cp_t,
        "ville_trouvee":     ville_t,
        "siren_trouve":      out_siren,
        "siret_trouve":      out_siret,
    }

    ok_nom = token_sim(intitule, nom_t) > 0.40
    if not ok_nom:
        return enriched, "red"

    checks = []
    if cp_o:      checks.append(cp_t == cp_o)
    if ville_o:   checks.append(token_sim(ville_o, ville_t) > 0.5)
    if adresse_o: checks.append(token_sim(adresse_o, adr_t) > 0.3)
    if siren_o:   checks.append(siren_t == siren_o)
    if siret_o:   checks.append(siret_t == siret_o)

    status = ("green" if (checks and all(checks)) else "orange")
    return enriched, status


