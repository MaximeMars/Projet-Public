    def _get_visible(self):
        show_all = self.var_show_all.get()
        gf = self.var_gfilter.get().lower()
        if gf == self._gf_placeholder.lower(): gf = ""

        result = []
        for rec in self.data:
            if not show_all and self._is_complete(rec): continue
            if gf:
                all_v = " ".join(str(v) for v in rec.values()).lower()
                if gf not in all_v: continue
            ok = True
            for key, var in self._col_filters.items():
                flt = var.get().lower().strip()
                if flt and flt not in str(rec.get(key,"")).lower():
                    ok = False; break
            if ok: result.append(rec)
        return result

    def refresh_table(self):
        if self.tree is None: return
        for item in self.tree.get_children():
            self.tree.delete(item)

        rows = self._get_visible()
        for i, rec in enumerate(rows):
            score   = rec.get("score","")
            siren_t = rec.get("siren_trouve","")
            has_sug = bool(rec.get("suggestions"))
            if score == "100":
                tag = "sc100"
            elif score in ("70","50"):
                tag = "sc70"
            elif score == "0" or siren_t in ("non trouvé","timeout","erreur","erreur réseau"):
                tag = "sc0" if siren_t else ("odd" if i % 2 else "even")
            elif has_sug:
                tag = "sugg"
            else:
                tag = "odd" if i % 2 else "even"

            chk = "☑" if rec.get("checked") else "☐"
            tva_st = rec.get("tva_statut", "")
            values = [chk,
                rec.get("code_sage",""),      rec.get("intitule",""),
                rec.get("adresse",""),        rec.get("complement",""),
                rec.get("ville",""),          rec.get("code_postal",""),
                rec.get("siren_base",""),     rec.get("tva_base",""),
                rec.get("siren_trouve",""),   rec.get("siret_trouve",""),
                rec.get("tva_calcule",""),    tva_st,
                rec.get("adresse_trouvee",""),rec.get("cp_trouve",""),
                rec.get("ville_trouvee",""),  score,
                rec.get("suggestions_txt","")]
            iid = rec.get("code_sage") or str(id(rec))
            # Combiner le tag de score/couleur avec le tag checked si coché
            tags = (tag, "checked") if rec.get("checked") else (tag,)
            self.tree.insert("", tk.END, iid=iid, values=values, tags=tags)

        self._status(f"{len(rows)} tiers affichés  /  {len(self.data)} total")

    @staticmethod
    def _is_complete(rec):
        return all(rec.get(k) for k in
                   ("siren_base","tva_base","intitule","adresse","ville","code_postal"))

