    def _search_thread(self, records):
        n = len(records)
        self._prog(0, f"0 / {n}")
        for i, rec in enumerate(records):
            try: self._sirene_lookup(rec)
            except: rec["siren_trouve"]="erreur"; rec["score"]="0"
            self._prog((i+1)/n*100, f"{i+1} / {n}  —  {rec.get('intitule','')[:50]}")
            time.sleep(0.4)
        self._running = False
        self.root.after(0, self.refresh_table)
        self._status(f"Recherche terminée — {n} tiers traités")

    def _sirene_lookup(self, rec):
        intitule = rec.get("intitule","").strip()
        adresse  = rec.get("adresse","").strip()
        ville    = rec.get("ville","").strip()
        cp       = rec.get("code_postal","").strip()
        if not intitule and not adresse:
            rec.update(siren_trouve="non trouvé",score="0"); return
        params = {"per_page":"10","q": intitule}
        if cp: params["code_postal"] = cp
        try:
            resp = requests.get("https://recherche-entreprises.api.gouv.fr/search",
                                params=params, timeout=8)
        except requests.Timeout:
            rec.update(siren_trouve="timeout",score="0"); return
        except:
            rec.update(siren_trouve="erreur réseau",score="0"); return
        if resp.status_code != 200:
            rec.update(siren_trouve="non trouvé",score="0"); return
        results = resp.json().get("results",[])
        if not results:
            rec.update(siren_trouve="non trouvé",score="0",
                       adresse_trouvee="",cp_trouve="",ville_trouvee=""); return
        best_score, best = 0, None
        for r in results:
            siege  = r.get("siege",{}) or {}
            r_adr  = " ".join(filter(None,[
                str(siege.get("numero_voie","") or "").strip(),
                str(siege.get("type_voie","")   or "").strip(),
                str(siege.get("libelle_voie","") or "").strip()]))
            r_cp   = str(siege.get("code_postal","")     or "").strip()
            r_vil  = str(siege.get("libelle_commune","") or "").strip()
            nom_r  = r.get("nom_raison_sociale","") or ""
            nom_ok = (normalize_str(intitule) in normalize_str(nom_r) or
                      normalize_str(nom_r) in normalize_str(intitule))
            adr_ok = addr_similarity(adresse, r_adr) > 0.45
            cp_ok  = (cp == r_cp)
            vil_ok = (normalize_str(ville) in normalize_str(r_vil) or
                      normalize_str(r_vil) in normalize_str(ville))
            sc = (100 if nom_ok and adr_ok and (cp_ok or vil_ok)
                  else 70 if adr_ok and cp_ok and vil_ok
                  else 50 if nom_ok else 0)
            if sc > best_score:
                best_score = sc
                best = dict(siren=r.get("siren",""),adresse=r_adr,cp=r_cp,ville=r_vil)
        if best and best_score > 0:
            rec.update(siren_trouve=best["siren"],score=str(best_score),
                       adresse_trouvee=best["adresse"],
                       cp_trouve=best["cp"],ville_trouvee=best["ville"])
        else:
            rec.update(siren_trouve="non trouvé",score="0",
                       adresse_trouvee="",cp_trouve="",ville_trouvee="")

