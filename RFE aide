# ── Helpers ────────────────────────────────────────────────────────────────────
def normalize(s: str) -> str:
    if not s:
        return ""
    s = str(s).upper().strip()
    s = unicodedata.normalize("NFD", s)
    s = "".join(c for c in s if unicodedata.category(c) != "Mn")
    s = _RE_NON_ALPHANUM.sub(" ", s)
    return _RE_SPACES.sub(" ", s).strip()


def token_sim(a: str, b: str) -> float:
    ta = set(normalize(a).split()) - _STOP
    tb = set(normalize(b).split()) - _STOP
    if not ta or not tb:
        return 0.0
    return len(ta & tb) / max(len(ta), len(tb))


def clean_cp(cp) -> str:
    if not cp:
        return ""
    return str(cp).strip().split(".")[0].zfill(5)


def clean_siren(s) -> str:
    return _RE_DIGITS_ONLY.sub("", str(s or ""))[:9]


def clean_siret(s) -> str:
    return _RE_DIGITS_ONLY.sub("", str(s or ""))[:14]


def compute_tva(siren_str: str) -> str:
    """N° TVA intracommunautaire FR (formule officielle)."""
    s = _RE_DIGITS_ONLY.sub("", str(siren_str or ""))
    if len(s) != 9:
        return ""
    key = (12 + 3 * (int(s) % 97)) % 97
    return f"FR{key:02d}{s}"


# ── Vérification VIES (TVA UE) ───────────────────────────────────────────────
# API REST VIES — deux endpoints pour assurer la compatibilité :
#   v2 (POST, post-2023) : /rest-api/check-vat-number  { countryCode, vatNumber }
#   v1 (GET,  pré-2023)  : /rest-api/ms/{cc}/vat/{vat}  (fallback)
_VIES_V2  = "https://ec.europa.eu/taxation_customs/vies/rest-api/check-vat-number"
_VIES_V1  = "https://ec.europa.eu/taxation_customs/vies/rest-api/ms/{ms}/vat/{vat}"
_VIES_HDR = {"Accept": "application/json", "Content-Type": "application/json",
             "User-Agent": "AideRFE/1.0"}
_VIES_TIMEOUT = 12
_VIES_RETRY_DELAY = 2.0   # secondes avant 1 retry


def vies_check(tva_str: str, session: requests.Session = None) -> str:
    """
    Vérifie un N° TVA intracommunautaire via l'API REST VIES de l'UE.
    Essaie d'abord l'API v2 (POST), puis fallback v1 (GET).
    Retourne : "✅ Valide", "❌ Invalide", "⚠ Timeout" ou "⚠ Erreur"
    """
    tva = str(tva_str or "").strip().upper().replace(" ", "")
    if len(tva) < 4 or not tva[:2].isalpha():
        return ""
    ms  = tva[:2]   # code pays (ex : FR)
    vat = tva[2:]   # numéro sans le code pays
    caller = session or requests

    def _parse(data: dict) -> str:
        return "✅ Valide" if data.get("isValid") or data.get("valid") else "❌ Invalide"

    # ── Tentative v2 (POST JSON) ──────────────────────────────────────────
    for attempt in range(2):
        try:
            r = caller.post(_VIES_V2,
                            json={"countryCode": ms, "vatNumber": vat},
                            headers=_VIES_HDR, timeout=_VIES_TIMEOUT)
            if r.status_code == 200:
                return _parse(r.json())
            if r.status_code in (404, 400):
                return "❌ Invalide"
            if r.status_code == 429:
                # Rate limit → attendre et réessayer une fois
                if attempt == 0:
                    time.sleep(_VIES_RETRY_DELAY)
                    continue
                return "⚠ Rate limit"
            break   # autre code HTTP → essaie v1
        except requests.exceptions.Timeout:
            if attempt == 0:
                time.sleep(_VIES_RETRY_DELAY)
                continue
            # Après retry → fallback v1
            break
        except Exception:
            break

    # ── Fallback v1 (GET) ─────────────────────────────────────────────────
    for attempt in range(2):
        try:
            r = caller.get(_VIES_V1.format(ms=ms, vat=vat),
                           headers=_VIES_HDR, timeout=_VIES_TIMEOUT)
            if r.status_code == 200:
                return _parse(r.json())
            if r.status_code in (404, 400):
                return "❌ Invalide"
            if r.status_code == 429:
                if attempt == 0:
                    time.sleep(_VIES_RETRY_DELAY)
                    continue
                return "⚠ Rate limit"
            return "⚠ Erreur"
        except requests.exceptions.Timeout:
            if attempt == 0:
                time.sleep(_VIES_RETRY_DELAY)
                continue
            return "⚠ Timeout"
        except Exception:
            return "⚠ Erreur"
    return "⚠ Erreur"


def api_get(params: dict, session: requests.Session = None) -> list:
    try:
        caller = session or requests
        r = caller.get(API_URL, params=params, headers=HEADERS, timeout=TIMEOUT)
        r.raise_for_status()
        return r.json().get("results", [])
    except Exception:
        return []


def best_etab(result: dict, cp_cible: str, siret_cible: str = "") -> dict:
    """Choisit l'établissement le plus pertinent dans un résultat API."""
    siege = result.get("siege") or {}
    # Parenthèses explicites : priorité correcte même si siege est falsy
    etabs = result.get("matching_etablissements") or ([siege] if siege else [])
    if not etabs:
        return siege

    if siret_cible:
        for e in etabs:
            if clean_siret(e.get("siret", "")) == siret_cible:
                return e

    cpn = clean_cp(cp_cible)
    if cpn:
        flt = [e for e in etabs if clean_cp(e.get("code_postal", "")) == cpn]
        if flt:
            etabs = flt

    for e in etabs:
        if e.get("est_siege"):
            return e
    return etabs[0]


def build_adr(etab: dict) -> str:
    parts = [str(etab.get(k, "") or "").strip()
             for k in ("numero_voie", "type_voie", "libelle_voie")]
    return (" ".join(p for p in parts if p)
            or str(etab.get("adresse", "") or "")).upper()


def _score(c: dict, etab: dict, intitule: str, adresse_o: str,
           cp_o: str, ville_o: str, siren_o: str, siret_o: str) -> float:
    nom = c.get("nom_complet") or c.get("nom_raison_sociale") or ""
    score = token_sim(intitule, nom) * 50

    c_siren = clean_siren(c.get("siren", ""))
    if siren_o and c_siren:
        score += 40 if c_siren == siren_o else -10

    if siret_o:
        score += 40 if clean_siret(etab.get("siret", "")) == siret_o else 0

    etab_cp = clean_cp(etab.get("code_postal", ""))
    if cp_o and etab_cp:
        if etab_cp == cp_o:           score += 35
        elif etab_cp[:3] == cp_o[:3]: score += 8
        elif etab_cp[:2] == cp_o[:2]: score += 3
        else:                          score -= 25

    ev = etab.get("libelle_commune") or etab.get("commune") or ""
    if ville_o and ev:
        score += token_sim(ville_o, ev) * 20
    if adresse_o:
        score += token_sim(adresse_o, build_adr(etab)) * 10
    return score


def _make_enriched(result: dict, etab: dict, mode: str) -> dict:
    siren_t = clean_siren(result.get("siren", ""))
    siret_t = clean_siret(etab.get("siret", ""))
    if "siret" in mode:
        out_siren, out_siret = "", siret_t
    elif "siren" in mode:
        out_siren, out_siret = siren_t, ""
    else:
        out_siren, out_siret = siren_t, siret_t
    return {
        "adresse_trouvee":   build_adr(etab),
        "complement_trouve": "",
        "cp_trouve":         clean_cp(etab.get("code_postal", "")),
        "ville_trouvee":     (etab.get("libelle_commune") or etab.get("commune") or "").upper(),
        "siren_trouve":      out_siren,
        "siret_trouve":      out_siret,
        "tva_calcule":       "",
        "vies_result":       "",
    }


def enrich_row(row: dict, session: requests.Session = None) -> tuple:
    """Returns (enriched_dict, status, suggestions_list).
    status : green | orange | red | suggestion
    suggestions_list : non-vide si sélection manuelle requise
    """
    intitule  = str(row.get("intitule",  "") or "").strip()
    adresse_o = str(row.get("adresse",   "") or "").strip()
    cp_o      = clean_cp(row.get("code_postal", ""))
    ville_o   = str(row.get("ville",     "") or "").strip()
    siren_o   = clean_siren(row.get("siren",  ""))
    siret_o   = clean_siret(row.get("siret",  ""))
    mode      = str(row.get("siren_ou_siret", "") or "").lower().strip()

    if not intitule:
        return {}, "", []

    has_geo = bool(cp_o or ville_o)
    get = lambda p: api_get(p, session)

    # ── 1. Récupération des candidats ─────────────────────────────────────
    candidates: list = []
    if siret_o and len(siret_o) == 14:
        candidates = get({"q": siret_o, "per_page": 5})
    if not candidates and siren_o and len(siren_o) == 9:
        candidates = get({"q": siren_o, "per_page": 5})
    if not candidates:
        p = {"q": intitule, "per_page": 25}
        if cp_o:
            p["code_postal"] = cp_o
        candidates = get(p)
    if not candidates and cp_o:
        candidates = get({"q": intitule, "per_page": 25})
    if not candidates:
        tokens = normalize(intitule).split()
        if len(tokens) > 1:
            candidates = get({"q": " ".join(tokens[:3]), "per_page": 15})

    # ── Fallback scraping si l'API ne donne rien du tout ──────────────────
    if not candidates:
        scraped = web_scrape_fallback(intitule, adresse_o, ville_o, cp_o, session)
        if scraped:
            return {}, "suggestion", scraped
        return {}, "red", []

    # ── 2. Résolution des établissements (une seule fois par candidat) ────
    resolved = [(c, best_etab(c, cp_o, siret_o)) for c in candidates]

    # ── 3. Filtre géo strict ──────────────────────────────────────────────
    if has_geo:
        geo_ok = []
        for c, etab in resolved:
            cp_match  = (not cp_o)    or clean_cp(etab.get("code_postal", "")) == cp_o
            vil_match = (not ville_o) or token_sim(
                ville_o, (etab.get("libelle_commune") or etab.get("commune") or "")) > 0.50
            if cp_match and vil_match:
                geo_ok.append((c, etab))

        if not geo_ok:
            dept = cp_o[:2] if cp_o else ""
            broad = (get({"q": intitule, "departement": dept, "per_page": 20}) if dept
                     else get({"q": intitule, "per_page": 20}))
            # Si la recherche élargie est aussi vide, essai scraping web
            if not broad:
                broad = web_scrape_fallback(intitule, adresse_o, ville_o, cp_o, session)
            return {}, "suggestion", broad[:20]

        resolved = geo_ok

    # ── 4. Scoring ────────────────────────────────────────────────────────
    best_score, best_c, best_e = -999.0, None, {}
    for c, etab in resolved:
        s = _score(c, etab, intitule, adresse_o, cp_o, ville_o, siren_o, siret_o)
        if s > best_score:
            best_score, best_c, best_e = s, c, etab

    if best_c is None or best_score < 8:
        # Même un score faible → proposer en suggestion plutôt que rouge
        scraped = web_scrape_fallback(intitule, adresse_o, ville_o, cp_o, session)
        if scraped:
            return {}, "suggestion", scraped
        return {}, "red", []

    nom_t    = best_c.get("nom_complet") or best_c.get("nom_raison_sociale") or ""
    enriched = _make_enriched(best_c, best_e, mode)

    if token_sim(intitule, nom_t) < 0.40:
        # Similarité insuffisante → proposer en suggestion
        scraped = web_scrape_fallback(intitule, adresse_o, ville_o, cp_o, session)
        if scraped:
            return enriched, "suggestion", scraped
        return enriched, "red", []

    # ── 5. Statut final ───────────────────────────────────────────────────
    checks = []
    if cp_o:      checks.append(enriched["cp_trouve"] == cp_o)
    if ville_o:   checks.append(token_sim(ville_o, enriched["ville_trouvee"]) > 0.5)
    if adresse_o: checks.append(token_sim(adresse_o, enriched["adresse_trouvee"]) > 0.3)
    if siren_o:   checks.append(enriched["siren_trouve"] == siren_o)
    if siret_o:   checks.append(enriched["siret_trouve"] == siret_o)
    return enriched, ("green" if checks and all(checks) else "orange"), []


def apply_suggestion(candidate: dict, cp_o: str, mode: str) -> dict:
    """Construit enriched depuis un candidat choisi manuellement, respecte le CP."""
    etab = best_etab(candidate, cp_o)
    return _make_enriched(candidate, etab, mode)


# ── Fallback scraping web ─────────────────────────────────────────────────────
# Utilisé quand l'API SIRENE ne trouve rien (red) ou que la liste suggestion
# est vide après filtre géo.
_RE_SIREN_PATTERN = re.compile(r'\b(\d{3}[\s.\-]?\d{3}[\s.\-]?\d{3})\b')
_SCRAPE_URLS = [
    # DuckDuckGo HTML (sans API key, résultats FR)
    ("https://html.duckduckgo.com/html/", {"kl": "fr-fr"}),
    # Bing (fallback)
    ("https://www.bing.com/search", {"setlang": "fr", "cc": "FR"}),
]


def web_scrape_fallback(intitule: str, adresse: str = "", ville: str = "",
                        cp: str = "", session: requests.Session = None) -> list:
    """
    Cherche des SIRENs via scraping web, puis valide sur l'API SIRENE.
    Appelé quand l'API ne renvoie rien (red) ou liste suggestion vide.
    """
    caller = session or requests
    hdrs   = {**HEADERS, "Accept-Language": "fr-FR,fr;q=0.9",
              "Accept": "text/html,application/xhtml+xml"}

    # ── Construction de la requête ────────────────────────────────────────
    parts = [intitule]
    if ville: parts.append(ville)
    if cp:    parts.append(cp)
    if adresse: parts.append(adresse.split()[0] if adresse.split() else "")
    query_siren = " ".join(p for p in parts if p) + " SIREN"

    # ── 1. Extraction de SIRENs via scraping ─────────────────────────────
    sirens: set = set()
    for base_url, extra_params in _SCRAPE_URLS:
        if len(sirens) >= 10:
            break
        try:
            resp = caller.get(
                base_url,
                params={"q": query_siren, **extra_params},
                headers=hdrs, timeout=10
            )
            if resp.ok:
                raw = _RE_SIREN_PATTERN.findall(resp.text)
                for m in raw:
                    s = _RE_DIGITS_ONLY.sub("", m)
                    if len(s) == 9 and s not in sirens:
                        # Filtre grossier : commence par un chiffre plausible
                        # (les SIRENs commencent par 1-9)
                        if s[0] != "0":
                            sirens.add(s)
        except Exception:
            continue

    # ── 2. Validation des SIRENs sur l'API SIRENE ─────────────────────────
    candidates: list = []
    seen_siren: set  = set()
    for siren in list(sirens)[:12]:
        hits = api_get({"q": siren, "per_page": 3}, session)
        for h in hits:
            s = h.get("siren", "")
            if s not in seen_siren:
                seen_siren.add(s)
                candidates.append(h)
        if len(candidates) >= 15:
            break

    # ── 3. Fallback : recherche textuelle large si aucun SIREN extrait ────
    if not candidates:
        tokens = normalize(intitule).split()
        for n in range(min(len(tokens), 4), 0, -1):
            hits = api_get({"q": " ".join(tokens[:n]), "per_page": 20}, session)
            if hits:
                candidates.extend(hits)
                break

    # ── 4. Tri par similarité avec l'intitulé ─────────────────────────────
    candidates.sort(
        key=lambda c: token_sim(
            intitule, c.get("nom_complet") or c.get("nom_raison_sociale") or ""),
        reverse=True
    )
    return candidates[:20]


