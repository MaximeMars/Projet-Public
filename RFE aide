    def _hsb_set(self, first, last):
        """Proxy entre xscrollcommand et hsb : synchro filtres + indicateur."""
        self._hsb.set(first, last)
        self._update_nav_indicator(float(first), float(last))
        # Synchroniser le Canvas de filtres
        try:
            self._flt_canvas.xview_moveto(first)
        except Exception:
            pass

    def _update_nav_indicator(self, first, last):
        """Affiche une mini-barre de progression de la position horizontale."""
        try:
            W   = 20   # largeur de la barre en caractères
            pos = int(first * W)
            vis = max(1, int((last - first) * W))
            bar = "─" * pos + "█" * vis + "─" * max(0, W - pos - vis)
            pct = int(first * 100)
            self._nav_pos_lbl.config(text=f"◄{bar}►  {pct}%")
        except Exception:
            pass

    def _scroll_to_col(self, col_id):
        """Fait défiler horizontalement pour rendre une colonne visible."""
        try:
            cols = list(self.tree["displaycolumns"])
            if cols in (["#all"], ("all",)):
                cols = [c[0] for c in COLUMNS]
            if col_id not in cols:
                return
            idx    = cols.index(col_id)
            total  = sum(self.tree.column(c, "width") for c in cols)
            offset = sum(self.tree.column(c, "width") for c in cols[:idx])
            frac   = offset / total if total else 0
            self.tree.xview_moveto(frac)
        except Exception:
            pass

