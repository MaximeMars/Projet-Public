def _xl_style_header(ws, n_src: int):
    """Applique la mise en forme de la ligne d'en-tête (partagée export + gabarit)."""
    for ci, cell in enumerate(ws[1], 1):
        is_src         = ci <= n_src
        cell.fill      = _XL_FILL_HDR_S if is_src else _XL_FILL_HDR_F
        cell.font      = _XL_FONT_HDR_S if is_src else _XL_FONT_HDR_F
        cell.alignment = _XL_ALIGN_HDR
        cell.border    = _XL_BRD
    ws.row_dimensions[1].height = 36
    return _XL_BRD


def _xl_style_data_row(ws, excel_row: int, brd, fill=None):
    for cell in ws[excel_row]:
        if fill:
            cell.fill  = fill
        cell.border    = brd
        cell.alignment = _XL_ALIGN_DATA
        cell.font      = _XL_FONT_DATA


def _xl_auto_width(ws):
    for col_idx, col in enumerate(ws.columns, 1):
        w = max((len(str(c.value or "")) for c in col), default=8)
        ws.column_dimensions[get_column_letter(col_idx)].width = min(max(w + 2, 10), 50)


