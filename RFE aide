    def btn_recherche(self):
        if not self.data:
            messagebox.showwarning("Recherche", "Aucune donnée chargée."); return
        if self._running:
            messagebox.showwarning("Recherche", "Traitement en cours."); return
        todo = [r for r in self.data if r.get("checked")]
        if not todo:
            messagebox.showwarning("Recherche", "Cochez les tiers à rechercher."); return
        if not messagebox.askyesno("Recherche SIRENE",
                f"Lancer la recherche pour {len(todo)} tiers ?"): return
        self._running = True
        threading.Thread(target=self._search_thread, args=(todo,), daemon=True).start()

    def _search_thread(self, records):
        import concurrent.futures, threading as _th

        n = len(records)
        self._prog(0, f"0 / {n}")
        done_count = [0]
        lock = _th.Lock()
        sem = _th.Semaphore(5)

        def _lookup_safe(rec):
            with sem:
                try:
                    self._sirene_lookup(rec)
                except Exception:
                    rec["siren_trouve"] = "erreur"
                    rec["score"] = "0"
                time.sleep(0.8)
            with lock:
                done_count[0] += 1
                pct = done_count[0] / n * 100
                self._prog(pct, "En cours de traitement…")

        with concurrent.futures.ThreadPoolExecutor(max_workers=5) as pool:
            futures = [pool.submit(_lookup_safe, rec) for rec in records]
            concurrent.futures.wait(futures)

        self._running = False
        self.root.after(0, self.refresh_table)
        self._status(f"Recherche terminée — {n} tiers traités")
        self._prog(100, "Terminé")

    def _sirene_lookup(self, rec):
        intitule = rec.get("intitule", "").strip()
        adresse  = rec.get("adresse",  "").strip()
        ville    = clean_ville(rec.get("ville", "").strip())
        cp_raw   = rec.get("code_postal", "").strip()
        cp       = clean_cp(cp_raw) or clean_cp(ville) or clean_cp(rec.get("ville",""))

        if not intitule and not adresse:
            rec.update(siren_trouve="non trouvé", siret_trouve="", score="0")
            return

        # ── Utilitaire requête API ────────────────────────────────────────────
        def _fetch(q, cp_filter=None, per_page=25):
            if not q: return []
            p = {"per_page": str(per_page), "q": q}
            if cp_filter:
                p["code_postal"] = cp_filter
            try:
                r = requests.get(
                    "https://recherche-entreprises.api.gouv.fr/search",
                    params=p, timeout=8)
                if r.status_code == 200:
                    return r.json().get("results", [])
            except requests.Timeout:
                rec.update(siren_trouve="timeout", siret_trouve="", score="0"); raise
            except Exception:
                rec.update(siren_trouve="erreur réseau", siret_trouve="", score="0"); raise
            return []

        def _fetch_robust(q, cp_filter=None):
            """Cherche : avec CP → sans CP → par mots individuels si toujours vide."""
            res = _fetch(q, cp_filter)
            if not res and cp_filter:
                res = _fetch(q, None)
            # Si toujours vide, chercher mot par mot (gestion des fautes de frappe)
            if not res and q:
                words = [w for w in normalize_str(q).split()
                         if len(w) > 3 and w not in
                         {"SARL","SAS","SA","EURL","SCI","SNC","GIE","EI","AGENCE","CABINET"}]
                for w in words[:3]:
                    partial = _fetch(w, cp_filter)
                    if not partial and cp_filter:
                        partial = _fetch(w, None)
                    res.extend(r for r in partial
                               if r.get("siren") not in {x.get("siren") for x in res})
                    if res: break
            return res

        # ── Ville fuzzy matching ──────────────────────────────────────────────
        def _ville_match(v1, v2):
            """True si les deux villes sont suffisamment proches."""
            n1 = normalize_str(v1).split()
            n2 = normalize_str(v2).split()
            if not n1 or not n2: return False
            # Correspondance exacte après normalisation
            if " ".join(n1) == " ".join(n2): return True
            # Au moins un mot significatif (>3 chars) commun
            sig1 = set(w for w in n1 if len(w) > 3)
            sig2 = set(w for w in n2 if len(w) > 3)
            if sig1 & sig2: return True
            # Première partie du nom suffit (ex: "SOLLIES" ⊂ "SOLLIES PONT")
            if n1[0] == n2[0] and len(n1[0]) > 4: return True
            return False

        # ── Extraction de l'enregistrement API ───────────────────────────────
        def _extract(r):
            siege   = r.get("siege", {}) or {}
            r_adr   = " ".join(filter(None, [
                str(siege.get("numero_voie",  "") or "").strip(),
                str(siege.get("type_voie",    "") or "").strip(),
                str(siege.get("libelle_voie", "") or "").strip()]))
            r_cp    = str(siege.get("code_postal",     "") or "").strip()
            r_vil   = str(siege.get("libelle_commune", "") or "").strip().title()
            nom_r   = (r.get("nom_raison_sociale") or r.get("nom_complet") or
                       r.get("nom_commercial") or siege.get("nom_commercial") or
                       (r.get("personne_morale_attributs") or {}).get("raison_sociale") or "")
            nom_r   = str(nom_r).strip()
            siren_r = r.get("siren", "")
            siret_r = str(siege.get("siret","") or r.get("siret","") or "").strip()
            return r_adr, r_cp, r_vil, nom_r, siren_r, siret_r

        # ── Lancer les recherches ─────────────────────────────────────────────
        results_name = []
        results_addr = []

        # Optimisation SIREN de base
        siren_base = rec.get("siren_base", "").strip()
        if siren_base and siren_base.isdigit() and len(siren_base) in (9, 14):
            try:
                direct = _fetch(siren_base[:9])
                if direct:
                    results_name = direct
            except Exception:
                pass

        try:
            if not results_name and intitule:
                results_name = _fetch_robust(intitule, cp or None)

            # Recherche par adresse : chercher les entreprises dans le CP/ville
            # L'API ne cherche pas par adresse → on récupère les entreprises
            # dans le secteur géo (CP) et on filtre par similarité d'adresse
            if cp:
                results_addr = _fetch(intitule or "a", cp, per_page=25)
                if not results_addr and ville:
                    # Essai département (2 premiers chiffres du CP)
                    dep_q = (intitule[:10] if intitule else "") or "entreprise"
                    results_addr = _fetch(dep_q, cp)
            elif ville:
                # Pas de CP : chercher par mots-clés ville + intitulé
                ville_words = [w for w in normalize_str(ville).split() if len(w) > 3]
                if ville_words and intitule:
                    results_addr = _fetch_robust(intitule + " " + ville_words[0])
        except Exception:
            return

        # ── Scoring ───────────────────────────────────────────────────────────
        NOM_STOP = {"SAS","SA","SARL","SNC","EURL","SCI","GIE","EI","ET",
                    "DE","DU","DES","LE","LA","LES","L","D","AGENCE","CABINET"}

        def _nom_match(ni, nr):
            if not ni or not nr: return False
            if ni in nr or nr in ni: return True
            wi = set(ni.split()) - NOM_STOP
            wr = set(nr.split()) - NOM_STOP
            if not wi or not wr: return False
            common = wi & wr
            # Au moins 1 mot significatif (>3 chars) en commun
            sig = [w for w in common if len(w) > 3]
            if sig: return True
            # Ou majorité des mots courts
            return len(common) >= max(1, min(len(wi), len(wr)) - 1)

        best_score, best = 0, None
        candidates_by_addr = []
        candidates_by_name = []
        seen_sirens = set()
        all_results = list(results_name)
        for r in results_addr:
            if r.get("siren") not in {x.get("siren") for x in all_results}:
                all_results.append(r)

        ni = normalize_str(intitule)

        for r in all_results:
            r_adr, r_cp, r_vil, nom_r, siren_r, siret_r = _extract(r)
            nr = normalize_str(nom_r)

            nom_ok  = _nom_match(ni, nr)
            adr_ok  = bool(adresse) and addr_similarity(adresse, r_adr) > 0.35
            cp_ok   = bool(cp) and (cp == r_cp)
            vil_ok  = bool(ville) and _ville_match(ville, r_vil)

            sc = (100 if nom_ok and adr_ok and (cp_ok or vil_ok)
                  else 100 if nom_ok and cp_ok
                  else 70  if nom_ok and (vil_ok or adr_ok)
                  else 70  if adr_ok and (cp_ok or vil_ok)
                  else 50  if nom_ok
                  else 0)

            tva_calc = calculate_tva_fr(siren_r)
            c = dict(siren=siren_r, siret=siret_r, nom=nom_r,
                     adresse=r_adr, cp=r_cp, ville=r_vil,
                     tva=tva_calc, score=sc)

            if sc > best_score:
                best_score = sc
                best = dict(siren=siren_r, siret=siret_r,
                            adresse=r_adr, cp=r_cp, ville=r_vil, nom=nom_r)

            if sc > 0:
                if adr_ok and (cp_ok or vil_ok):
                    candidates_by_addr.append(c)
                else:
                    candidates_by_name.append(c)
            seen_sirens.add(siren_r)

        # ── Mise à jour du record ─────────────────────────────────────────────
        if best and best_score > 0:
            rec.update(siren_trouve=best["siren"],
                       siret_trouve=best["siret"] if best["siret"] else "",
                       score=str(best_score),
                       adresse_trouvee=best["adresse"],
                       cp_trouve=best["cp"], ville_trouvee=best["ville"])
        else:
            rec.update(siren_trouve="non trouvé", siret_trouve="",
                       score="0",
                       adresse_trouvee="", cp_trouve="", ville_trouvee="")

        best_siren = best["siren"] if best else ""
        merged = {c["siren"]: c for c in candidates_by_addr}
        for c in candidates_by_name:
            if c["siren"] not in merged:
                merged[c["siren"]] = c
        suggestions = [c for c in merged.values() if c["siren"] != best_siren]

        rec["suggestions"] = suggestions
        if suggestions:
            noms = ", ".join(s["nom"] for s in suggestions[:3])
            extra = f" +{len(suggestions)-3}" if len(suggestions) > 3 else ""
            rec["suggestions_txt"] = f"💡 {len(suggestions)} : {noms}{extra}"
        else:
            rec["suggestions_txt"] = ""


