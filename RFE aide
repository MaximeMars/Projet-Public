    def btn_mise_a_jour(self):
        if not self.db_conn:
            messagebox.showerror("Erreur","Non connecté. Utilisez le bouton A."); return
        INVALID = ("non trouvé","erreur","erreur réseau","timeout","")
        todo = [r for r in self.data
                if r.get("checked") and r.get("siren_trouve") not in INVALID]
        if not todo:
            messagebox.showwarning("Mise à jour",
                "Aucun tiers coché avec SIREN trouvé.\nLancez d'abord Recherche (D)."); return
        if not messagebox.askyesno("Mise à jour SQL",
                f"Mettre à jour {len(todo)} tiers dans F_COMPTET ?\n\n"
                "CT_Siren, CT_NumPaysTVA, CT_Adresse, CT_CodePostal, CT_Ville\n\n"
                "Seules les cases cochées sont mises à jour."): return
        threading.Thread(target=self._update_thread, args=(todo,), daemon=True).start()

    def _update_thread(self, records):
        n, errors = len(records), 0
        self._prog(0, f"0 / {n}")
        try:
            cursor = self.db_conn.cursor()
            for i, rec in enumerate(records):
                try:
                    pairs = [("CT_Siren","siren_trouve"),("CT_NumPaysTVA","tva_calcule"),
                             ("CT_Adresse","adresse_trouvee"),("CT_CodePostal","cp_trouve"),
                             ("CT_Ville","ville_trouvee")]
                    sets, params = [], []
                    for col, key in pairs:
                        v = rec.get(key,"").strip()
                        if v: sets.append(f"{col} = ?"); params.append(v)
                    if sets:
                        params.append(rec["code_sage"])
                        cursor.execute(f"UPDATE F_COMPTET SET {', '.join(sets)} WHERE CT_Num = ?", params)
                except: errors += 1
                self._prog((i+1)/n*100, f"{i+1} / {n}")
                time.sleep(0.05)
            self.db_conn.commit()
            msg = f"Mise à jour : {n-errors} succès, {errors} erreur(s)."
            self.root.after(0, lambda m=msg: messagebox.showinfo("Mise à jour", m))
            self._status(msg)
        except Exception as e:
            self.root.after(0, lambda: messagebox.showerror("Erreur SQL", str(e)))

