    # ── Import ───────────────────────────────────────────────────────────────
    def _import(self):
        path = filedialog.askopenfilename(
            title="Importer un fichier Excel",
            filetypes=[("Excel", "*.xlsx *.xls"), ("Tous", "*.*")])
        if not path:
            return
        try:
            df = pd.read_excel(path, header=0, dtype=str).fillna("")
            df.columns = [str(c).strip() for c in df.columns]
            raw_lower  = {c.lower(): c for c in df.columns}
            col_index  = {}
            for key, alist in COL_ALIASES.items():
                for alias in alist:
                    if alias.lower() in raw_lower:
                        col_index[key] = raw_lower[alias.lower()]
                        break

            self.df             = df
            self.col_index      = col_index
            self.results        = [None] * len(df)
            self._row_cache     = [None] * len(df)      # lazy
            self._cache_dirty   = set(range(len(df)))   # tout est dirty
            self._counts     = {"green": 0, "orange": 0, "red": 0, "suggestion": 0, "pending": len(df)}
            self._done_count = 0
            self._col_filters.clear()
            self._sync_heading_icons()
            self._update_filter_indicator()

            n = len(df)
            self._lbl_file.config(
                text=f"📄 {os.path.basename(path)}  ·  {n} ligne{'s' if n > 1 else ''}")
            self._btn_search.config_state(True)
            self._btn_export.config_state(False)
            self._btn_tva.config_state(False)
            self._btn_vies.config_state(False)
            self._sc_total.config(text=str(n))
            for sc in (self._sc_green, self._sc_orange, self._sc_red):
                sc.config(text="0")
            self._sc_sugg.config(text="0")
            self._sc_pend.config(text=str(n))
            self._progress["value"] = 0
            self._progress["maximum"] = max(n, 1)
            self._statusbar.config(text=f"✅  {n} ligne(s) chargée(s).")
            self._refresh_table()
        except Exception as e:
            messagebox.showerror("Erreur import", str(e))

    def _gc(self, row, key: str) -> str:
        """Lit une cellule mappée depuis une ligne DataFrame."""
        col = self.col_index.get(key)
        # col_index est fixe après import : pas besoin de vérifier row.index à chaque fois
        return str(row[col]).strip() if col else ""

    def _build_row_dict(self, idx: int) -> dict:
        """Construit le dict de rendu pour une ligne (résultat + source)."""
        row      = self.df.iloc[idx]
        res      = self.results[idx] or {}
        enriched = res.get("enriched", {})
        status   = res.get("status", "pending")
        return {
            "intitule":      self._gc(row, "intitule"),
            "adresse":        self._gc(row, "adresse"),
            "code_postal":    self._gc(row, "code_postal"),
            "ville":          self._gc(row, "ville"),
            "siren":          self._gc(row, "siren"),
            "siret":          self._gc(row, "siret"),
            "siren_ou_siret": self._gc(row, "siren_ou_siret"),
            "adresse_trouvee":enriched.get("adresse_trouvee", ""),
            "cp_trouve":      enriched.get("cp_trouve", ""),
            "ville_trouvee":  enriched.get("ville_trouvee", ""),
            "siren_trouve":   enriched.get("siren_trouve", ""),
            "siret_trouve":   enriched.get("siret_trouve", ""),
            "tva_calcule":    enriched.get("tva_calcule", ""),
            "vies_result":    enriched.get("vies_result", ""),
            "statut":         _STATUS_LABEL.get(status, "⏳ En attente"),
            "_status":        status,
            "_idx":           idx,
        }

    def _get_row_dict(self, idx: int) -> dict:
        """Retourne le dict du cache, en reconstruisant si dirty."""
        if idx in self._cache_dirty or self._row_cache[idx] is None:
            self._row_cache[idx] = self._build_row_dict(idx)
            self._cache_dirty.discard(idx)
        return self._row_cache[idx]

    def _invalidate(self, idx: int):
        """Marque une ligne comme dirty."""
        self._cache_dirty.add(idx)

    def _on_search_change(self, *_):
        """Debounce : attend 200 ms après la dernière frappe avant de rafraîchir."""
        if self._debounce_id:
            self.after_cancel(self._debounce_id)
        self._debounce_id = self.after(200, self._refresh_table)

    # ── Refresh table ─────────────────────────────────────────────────────────
    def _refresh_table(self):
        if self.df is None:
            return
        self._debounce_id = None
        flt    = self._quick_filter.get()
        search = normalize(self._search_var.get())

        # Reconstruire uniquement les entrées dirty
        for i in list(self._cache_dirty):
            self._row_cache[i] = self._build_row_dict(i)
        self._cache_dirty.clear()

        self._tree.delete(*self._tree.get_children())
        display = []

        for rd in self._row_cache:
            if rd is None:
                continue
            st = rd["_status"]

            if flt == "Vert"       and st != "green":      continue
            if flt == "Orange"     and st != "orange":     continue
            if flt == "Rouge"      and st != "red":        continue
            if flt == "Suggestion" and st != "suggestion": continue
            if flt == "En attente" and st != "pending":    continue

            if search:
                # Blob uniquement sur les clés affichables (pas _check/_status/_idx)
                blob = normalize(" ".join(
                    str(rd.get(k, "")) for k in ALL_COL_KEYS if not k.startswith("_")
                ))
                if search not in blob:
                    continue

            if any(allowed is not None
                   and str(rd.get(_COL_KEY.get(lbl, ""), "")) not in allowed
                   for lbl, allowed in self._col_filters.items()):
                continue

            display.append(rd)

        if self._sort_col and self._sort_col in ALL_COL_LABELS:
            sk = _COL_KEY[self._sort_col]
            display.sort(key=lambda r: str(r.get(sk, "")), reverse=self._sort_rev)

        for rd in display:
            st  = rd["_status"]
            tag = st if st in ("green", "orange", "red", "suggestion") else "pending"
            self._tree.insert("", "end", iid=str(rd["_idx"]), tags=(tag,),
                              values=tuple(rd.get(k, "") for k in ALL_COL_KEYS))

        # Stats depuis le compteur incrémental (O(1))
        self._sc_green.config(text=str(self._counts["green"]))
        self._sc_orange.config(text=str(self._counts["orange"]))
        self._sc_red.config(text=str(self._counts["red"]))
        self._sc_sugg.config(text=str(self._counts.get("suggestion", 0)))
        self._sc_pend.config(text=str(self._counts.get("pending", 0)))
        # Le compteur est mis à jour par <<TreeviewSelect>> automatiquement

    # ── Recherche ─────────────────────────────────────────────────────────────
    def _start_search(self, only_checked: bool = False):
        if self.df is None:
            return
        self._running = True
        for b in (self._btn_search, self._btn_import,
                  self._btn_export, self._btn_tva, self._btn_vies):
            b.config_state(False)
        self._btn_stop.config_state(True)
        if only_checked:
            to_search = frozenset(int(iid) for iid in self._tree.selection())
        else:
            to_search = frozenset(range(len(self.df)))
        self._done_count = 0
        self._progress["value"] = 0
        self._progress["maximum"] = max(len(to_search), 1)
        threading.Thread(target=self._worker, args=(to_search,), daemon=True).start()

    def _stop(self):
        self._running = False
        self._btn_stop.config_state(False)
        self._statusbar.config(text="⏹  Recherche interrompue.")

    def _worker(self, to_search: set):
        """try/finally garantit que done est toujours envoyé."""
        try:
            with requests.Session() as session:
                session.headers.update(HEADERS)
                for idx in sorted(to_search):
                    if not self._running:
                        break
                    row      = self.df.iloc[idx]
                    intitule = self._gc(row, "intitule")
                    if not intitule:
                        self.q.put(("result", idx, {}, "", [], None))
                        continue
                    row_dict = {k: self._gc(row, k) for k in self.col_index}
                    try:
                        enriched, status, suggestions = enrich_row(row_dict, session)
                    except Exception:
                        enriched, status, suggestions = {}, "red", []
                    self.q.put(("result", idx, enriched, status, suggestions, None))
                    time.sleep(0.20)
        except Exception:
            pass
        finally:
            self.q.put(("done", None, None, None, None, None))

    def _poll_queue(self):
        try:
            while True:
                kind, idx, enriched, status, suggestions, _extra = self.q.get_nowait()
                if kind == "done":
                    self._running = False
                    for b in (self._btn_search, self._btn_import,
                              self._btn_export, self._btn_tva, self._btn_vies):
                        b.config_state(True)
                    self._btn_stop.config_state(False)
                    self._statusbar.config(
                        text="✅  Terminé — Lancez «Calculer N° TVA» ou exportez.")
                    self._refresh_table()
                    break

                if kind == "result":
                    # Compteurs incrémentaux O(1)
                    old_status = (self.results[idx] or {}).get("status", "")
                    if old_status in self._counts:
                        self._counts[old_status] -= 1
                    self.results[idx] = {"enriched": enriched, "status": status,
                                         "suggestions": suggestions}
                    if status in self._counts:
                        self._counts[status] += 1

                    self._done_count += 1
                    self._invalidate(idx)
                    self._progress["value"] = self._done_count
                    name = self._gc(self.df.iloc[idx], "intitule")
                    pct  = self._done_count / max(self._progress["maximum"], 1) * 100
                    icon = {"green":"✅","orange":"🟠","red":"❌",
                            "suggestion":"🔍","":"⏭"}.get(status, "⏳")
                    self._lbl_prog.config(text=f"{icon}  {self._done_count}   {name[:55]}")
                    self._statusbar.config(
                        text=f"Enrichissement : {pct:.0f}%  ({self._done_count}) — {name[:65]}")

                    # Mise à jour ciblée de la ligne dans le Treeview
                    rd  = self._get_row_dict(idx)
                    tag = status if status in ("green","orange","red","suggestion") else "pending"
                    try:
                        if self._tree.exists(str(idx)):
                            self._tree.item(str(idx), tags=(tag,),
                                values=tuple(rd.get(k, "") for k in ALL_COL_KEYS))
                    except Exception:
                        pass

                    self._sc_green.config(text=str(self._counts["green"]))
                    self._sc_orange.config(text=str(self._counts["orange"]))
                    self._sc_red.config(text=str(self._counts["red"]))
                    self._sc_sugg.config(text=str(self._counts.get("suggestion", 0)))
                    self._sc_pend.config(text=str(self._counts.get("pending", 0)))
                if kind == "vies":
                    # ("vies", df_idx, done_count, total, tva, vies_result)
                    done   = enriched   # done_count
                    total  = status     # total
                    tva    = suggestions  # tva string
                    result = _extra     # vies result string
                    self._progress["value"] = done
                    icon = "✅" if "Valide" in str(result) else ("❌" if result else "⚠")
                    self._statusbar.config(
                        text=f"VIES : {done}/{total}  {icon} {tva}  → {result}")
                    # Mise à jour directe de la ligne dans le Treeview
                    self._invalidate(idx)
                    rd  = self._get_row_dict(idx)
                    tag = rd.get("_status","pending")
                    tag = tag if tag in ("green","orange","red","suggestion") else "pending"
                    try:
                        if self._tree.exists(str(idx)):
                            self._tree.item(str(idx), tags=(tag,),
                                values=tuple(rd.get(k,"") for k in ALL_COL_KEYS))
                    except Exception:
                        pass

                if kind == "vies_done":
                    self._running = False
                    for b in (self._btn_vies, self._btn_tva, self._btn_search,
                              self._btn_import, self._btn_export):
                        b.config_state(True)
                    self._btn_stop.config_state(False)
                    self._col_visible["Ctrl VIES"] = True
                    self._apply_displaycols()
                    self._refresh_table()
                    n_valid   = sum(1 for r in self.results
                                   if r and "Valide" in r.get("enriched",{}).get("vies_result",""))
                    n_invalid = sum(1 for r in self.results
                                   if r and "Invalide" in r.get("enriched",{}).get("vies_result",""))
                    n_err     = sum(1 for r in self.results
                                   if r and "⚠" in r.get("enriched",{}).get("vies_result",""))
                    self._statusbar.config(
                        text=f"✅ VIES terminé — {n_valid} valide(s)  {n_invalid} invalide(s)  {n_err} erreur(s)")
                    messagebox.showinfo(
                        "Vérification VIES ✅",
                        f"Contrôle terminé :\n\n"
                        f"  ✅ Valides   : {n_valid}\n"
                        f"  ❌ Invalides : {n_invalid}\n"
                        f"  ⚠  Erreurs  : {n_err}\n\n"
                        "La colonne «Ctrl VIES» est maintenant visible.")
                    # Pas de break : vider la queue entièrement

        except queue.Empty:
            pass
        self.after(80, self._poll_queue)

    # ── Calcul TVA ────────────────────────────────────────────────────────────
    def _compute_tva_all(self):
        if self.df is None:
            return
        n = 0
        for idx, res in enumerate(self.results):
            if not res:
                continue
            siren = res.get("enriched", {}).get("siren_trouve", "")
            tva   = compute_tva(siren)
            if tva:
                res["enriched"]["tva_calcule"] = tva
                self._invalidate(idx)
                n += 1
        self._col_visible["N° TVA"] = True
        self._apply_displaycols()
        self._refresh_table()
        self._btn_vies.config_state(True)
        self._statusbar.config(text=f"✅  {n} N° TVA calculés. Lancez «Vérification VIES» pour contrôle.")
        messagebox.showinfo("TVA calculée ✅",
            f"{n} numéro(s) TVA calculés.\n\n"
            "Formule : FR + clé 2 chiffres + SIREN\n"
            "Clé = (12 + 3×(SIREN mod 97)) mod 97\n\n"
            "La colonne «N° TVA» a été affichée automatiquement.")

    # ── Vérification VIES ────────────────────────────────────────────────────
    def _verify_vies_all(self):
        """Lance la vérification VIES sur toutes les lignes ayant un N° TVA calculé.
        Tourne dans un thread pour ne pas bloquer l'UI."""
        if self.df is None:
            return

        # Compte les TVA disponibles
        to_check = [
            idx for idx, res in enumerate(self.results)
            if res and res.get("enriched", {}).get("tva_calcule", "")
        ]
        if not to_check:
            messagebox.showinfo(
                "Aucun N° TVA",
                "Aucun numéro TVA disponible.\n"
                "Lancez d'abord «Calculer N° TVA».")
            return

        # Désactive les boutons pendant la vérification
        for b in (self._btn_vies, self._btn_tva, self._btn_search,
                  self._btn_import, self._btn_export):
            b.config_state(False)
        self._btn_stop.config_state(True)
        self._progress["value"] = 0
        self._progress["maximum"] = len(to_check)
        self._statusbar.config(
            text=f"Vérification VIES : 0/{len(to_check)} en cours…")

        self._running = True   # permet à Arrêter de couper le worker VIES
        threading.Thread(
            target=self._vies_worker,
            args=(to_check,),
            daemon=True
        ).start()

    def _vies_worker(self, to_check: list):
        """Thread de vérification VIES.
        try/finally garantit que vies_done est toujours envoyé (UI jamais bloquée)."""
        try:
            with requests.Session() as session:
                session.headers.update(_VIES_HDR)
                for done, idx in enumerate(to_check, 1):
                    if not self._running:
                        break
                    res      = self.results[idx] or {}
                    enriched = res.get("enriched", {})
                    tva      = enriched.get("tva_calcule", "")
                    result   = vies_check(tva, session) if tva else ""
                    enriched["vies_result"] = result
                    self._invalidate(idx)
                    self.q.put(("vies", idx, done, len(to_check), tva, result))
                    time.sleep(0.5)
        except Exception:
            pass
        finally:
            self.q.put(("vies_done", None, None, None, None, None))

    # ── Double-clic ───────────────────────────────────────────────────────────
    def _on_dbl_click(self, event):
        """Double-clic gauche → détail de la ligne.
        Ignoré si le guard suggestion est actif (un clic vient d'ouvrir la suggestion)."""
        if self._sugg_guard or event.num != 1:
            return
        region = self._tree.identify_region(event.x, event.y)
        iid    = self._tree.identify_row(event.y)
        if region not in ("cell", "tree") or not iid:
            return
        self._show_detail(int(iid))

    def _open_suggestions(self, idx: int):
        """Ouvre une unique SuggestionWindow modale pour la ligne idx."""
        # Ferme toute fenêtre précédente
        if self._suggestion_win is not None:
            try:
                if self._suggestion_win.winfo_exists():
                    self._suggestion_win.grab_release()
                    self._suggestion_win.destroy()
            except Exception:
                pass
            self._suggestion_win = None

        res        = self.results[idx] or {}
        candidates = res.get("suggestions", [])
        rd         = self._get_row_dict(idx)

        if not candidates:
            messagebox.showinfo("Pas de suggestions",
                                "Aucune suggestion disponible.\n"
                                "Relancez la recherche pour cette ligne.")
            return

        def _on_pick(candidate):
            mode    = self._gc(self.df.iloc[idx], "siren_ou_siret").lower()
            cp_orig = self._gc(self.df.iloc[idx], "code_postal")
            try:
                enriched = apply_suggestion(candidate, cp_orig, mode)
            except Exception as e:
                messagebox.showerror("Erreur", f"Impossible d'appliquer la suggestion :\n{e}")
                return
            # Mise à jour des compteurs : décrémente l'ancien statut, incrémente orange
            old_st = (self.results[idx] or {}).get("status", "")
            if old_st in self._counts:
                self._counts[old_st] -= 1
            self._counts["orange"] = self._counts.get("orange", 0) + 1
            self.results[idx] = {"enriched": enriched,
                                  "status": "orange", "suggestions": []}
            self._invalidate(idx)
            self._refresh_table()
            self._statusbar.config(
                text=f"✅  Suggestion appliquée pour «{rd.get('intitule', '')}»")

        self._suggestion_win = SuggestionWindow(
            self,
            rd.get("intitule", ""),
            rd.get("code_postal", ""),
            rd.get("ville", ""),
            candidates,
            _on_pick,
        )

