def csv_row_to_record(row):
    # Normaliser une clé : minuscules, sans accents, sans tirets/underscores
    def _nk(s):
        import unicodedata as _ud
        s = str(s).lower().strip()
        s = _ud.normalize("NFD", s)
        s = "".join(c for c in s if _ud.category(c) != "Mn")
        return s.replace("_", " ").replace("-", " ")

    MAP = {
        # Code tiers / Sage
        "code sage":     "code_sage",
        "code tiers":    "code_sage",
        "code":          "code_sage",
        "num":           "code_sage",
        "numero":        "code_sage",
        "ct num":        "code_sage",
        # Intitulé
        "intitule":      "intitule",
        "intitule tiers":"intitule",
        "raison sociale":"intitule",
        "nom":           "intitule",
        "denomination":  "intitule",
        "libelle":       "intitule",
        # Adresse
        "adresse":       "adresse",
        "adresse 1":     "adresse",
        "adresse1":      "adresse",
        "rue":           "adresse",
        "voie":          "adresse",
        # Complément
        "complement":    "complement",
        "adresse 2":     "complement",
        "adresse2":      "complement",
        "bat":           "complement",
        "batiment":      "complement",
        # Ville
        "ville":         "ville",
        "commune":       "ville",
        "localite":      "ville",
        # CP
        "code postal":   "code_postal",
        "cp":            "code_postal",
        "codepostal":    "code_postal",
        "zip":           "code_postal",
        # SIREN/SIRET base
        "siren":         "siren_base",
        "siret":         "siren_base",
        "siren base":    "siren_base",
        "siret base":    "siren_base",
        "ct siret":      "siren_base",
        "num siren":     "siren_base",
        "num siret":     "siren_base",
        # TVA base
        "tva":           "tva_base",
        "tva base":      "tva_base",
        "num tva":       "tva_base",
        "numero tva":    "tva_base",
        "identifiant":   "tva_base",
        "ct identifiant":"tva_base",
        # ── Variantes export (suffixe "source") ──────────
        "adresse (source)":    "adresse",
        "adresse1 (source)":   "adresse",
        "complement (source)": "complement",
        "ville (source)":      "ville",
        "cp (source)":         "code_postal",
        "code postal (source)":"code_postal",
        "siret base":          "siren_base",
        "siren base":          "siren_base",
        # ── Résultats re-importables ──────────────────────
        "siren trouve":        "siren_base",
        "siret trouve":        "siren_base",
        "adresse trouvee":     "adresse",
        "cp trouve":           "code_postal",
        "ville trouvee":       "ville",
        "tva calcule":         "tva_base",
    }

    rec = make_record()
    for k, v in row.items():
        key = MAP.get(_nk(k))
        if key:
            rec[key] = str(v).strip()
    if rec["ville"]:
        rec["ville"] = rec["ville"].title()
    return rec


