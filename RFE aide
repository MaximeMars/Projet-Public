# ── Fenêtre suggestions ───────────────────────────────────────────────────────
class SuggestionWindow(tk.Toplevel):
    """
    Fenêtre modale de sélection manuelle d'un candidat.
    Garanties :
      - Une seule instance par ligne (gérée par App._suggestion_win)
      - Modale (grab_set) : bloque l'interaction parent pendant la sélection
      - Double-clic OU bouton "Appliquer" pour valider
      - Bouton "Ignorer" pour passer sans rien choisir
    """
    def __init__(self, parent, intitule, cp_orig, ville_orig, candidates, on_pick):
        super().__init__(parent)
        self.title(f"Suggestions — {intitule[:60]}")
        self.geometry("860x520")
        self.configure(bg=BG)
        self.resizable(True, True)
        self.transient(parent)   # reste au-dessus du parent
        self._candidates = candidates
        self._on_pick    = on_pick
        self._tree_ref   = None  # référence au Treeview interne

        self._build(intitule, cp_orig, ville_orig)

        self.lift()
        self.grab_set()          # modal : bloque le reste de l'UI
        self.protocol("WM_DELETE_WINDOW", self._on_cancel)
        self.bind("<Escape>", lambda e: self._on_cancel())

    def _build(self, intitule, cp_orig, ville_orig):
        tk.Frame(self, bg=PURPLE, height=4).pack(fill="x")

        hdr = tk.Frame(self, bg=CARD)
        hdr.pack(fill="x")
        tk.Label(hdr, text=f"🔍  Suggestions pour  «{intitule}»",
                 bg=CARD, fg=TEXT, font=("Segoe UI", 11, "bold"),
                 pady=12, padx=16).pack(side="left")
        zone = f"{cp_orig} {ville_orig}".strip()
        if zone:
            tk.Label(hdr, text=f"Zone d'origine : {zone}",
                     bg=CARD, fg=TEXT2, font=("Segoe UI", 9), padx=16).pack(side="right")
        tk.Frame(self, bg=BORDER, height=1).pack(fill="x")

        info = tk.Frame(self, bg=PURPLE_BG)
        info.pack(fill="x", padx=14, pady=(8, 4))
        tk.Label(info,
                 text="⚠  Aucun résultat exact trouvé dans la zone demandée. "
                      "Sélectionnez une ligne puis cliquez «Appliquer», ou double-cliquez.",
                 bg=PURPLE_BG, fg=PURPLE, font=("Segoe UI", 8, "bold"),
                 wraplength=820, justify="left", padx=10, pady=6).pack(anchor="w")

        # ── Tableau des suggestions ──────────────────────────────────────
        tf = tk.Frame(self, bg=BG)
        tf.pack(fill="both", expand=True, padx=14, pady=(4, 0))

        cols   = ("Nom", "SIREN", "Adresse", "CP", "Ville", "Activité")
        widths = (210,    90,      220,       60,   130,     150)
        tree   = ttk.Treeview(tf, columns=cols, show="headings", selectmode="browse")
        for c, w in zip(cols, widths):
            tree.heading(c, text=c)
            tree.column(c, width=w, anchor="w", minwidth=40)

        vsb = ttk.Scrollbar(tf, orient="vertical", command=tree.yview)
        tree.configure(yscroll=vsb.set)
        tree.grid(row=0, column=0, sticky="nsew")
        vsb.grid(row=0, column=1, sticky="ns")
        tf.rowconfigure(0, weight=1)
        tf.columnconfigure(0, weight=1)

        for i, c in enumerate(self._candidates[:20]):
            nom  = c.get("nom_complet") or c.get("nom_raison_sociale") or "—"
            siren = c.get("siren", "")
            etab  = best_etab(c, cp_orig)   # tient compte du CP d'origine
            tree.insert("", "end", iid=str(i),
                        values=(nom, siren, build_adr(etab),
                                clean_cp(etab.get("code_postal", "")),
                                (etab.get("libelle_commune") or "").upper(),
                                str(c.get("activite_principale", "") or "")[:35]))

        self._tree_ref = tree
        tree.bind("<Double-1>",  self._on_tree_dbl)
        tree.bind("<Return>",    lambda e: self._apply())

        # ── Barre de boutons ─────────────────────────────────────────────
        bf = tk.Frame(self, bg=CARD2)
        bf.pack(fill="x", pady=(6, 0))

        tk.Label(bf, text="Sélectionnez une ligne et cliquez Appliquer",
                 bg=CARD2, fg=TEXT3, font=("Segoe UI", 8),
                 padx=16, pady=8).pack(side="left")

        tk.Button(bf, text="Annuler / Ignorer", command=self._on_cancel,
                  bg=CARD2, fg=TEXT2, relief="flat", font=("Segoe UI", 9),
                  cursor="hand2", padx=14, pady=8).pack(side="right", padx=4, pady=6)

        tk.Button(bf, text="✔  Appliquer", command=self._apply,
                  bg=ACCENT, fg="white", relief="flat",
                  font=("Segoe UI", 9, "bold"), cursor="hand2",
                  padx=16, pady=8).pack(side="right", padx=8, pady=6)

    def _get_selected_idx(self) -> int | None:
        """Retourne l'index candidat sélectionné, ou None."""
        if self._tree_ref is None:
            return None
        sel = self._tree_ref.selection()
        if not sel:
            return None
        try:
            return int(sel[0])
        except (ValueError, IndexError):
            return None

    def _on_tree_dbl(self, event):
        """Double-clic : vérifie que c'est bien une cellule (pas un en-tête)."""
        region = self._tree_ref.identify_region(event.x, event.y)
        if region not in ("cell", "tree"):
            return
        self._apply()

    def _apply(self):
        idx = self._get_selected_idx()
        if idx is None:
            messagebox.showwarning("Aucune sélection",
                                   "Veuillez sélectionner une ligne.",
                                   parent=self)
            return
        if idx < len(self._candidates):
            try:
                self._on_pick(self._candidates[idx])
            except Exception as e:
                messagebox.showerror("Erreur", str(e), parent=self)
                return
        self._close()

    def _on_cancel(self):
        self._close()

    def _close(self):
        try:
            self.grab_release()
        except Exception:
            pass
        self.destroy()


