    # ── Table avec filtres par colonne ────────────────
    def _build_table(self, parent):
        # Conteneur blanc avec légère ombre
        card = tk.Frame(parent, bg=C_WHITE,
                        relief="flat", bd=0)
        card.pack(fill=tk.BOTH, expand=True)
        tk.Frame(card, bg=C_BORDER, height=1).pack(fill=tk.X)

        # Frame pour scrollbars
        tree_frame = tk.Frame(card, bg=C_WHITE)
        tree_frame.pack(fill=tk.BOTH, expand=True)

        vsb = ttk.Scrollbar(tree_frame, orient="vertical")
        hsb = ttk.Scrollbar(tree_frame, orient="horizontal")
        vsb.pack(side=tk.RIGHT,  fill=tk.Y)
        hsb.pack(side=tk.BOTTOM, fill=tk.X)

        col_ids = [c[0] for c in COLUMNS]
        self.tree = ttk.Treeview(
            tree_frame,
            columns=col_ids,
            show="headings",
            style="Modern.Treeview",
            yscrollcommand=vsb.set,
            xscrollcommand=hsb.set)
        vsb.config(command=self.tree.yview)
        hsb.config(command=self.tree.xview)

        # Configuration des colonnes
        for cid, label, width, key, filtrable in COLUMNS:
            sort_arrow = ""
            self.tree.heading(
                cid,
                text=f"{label} {sort_arrow}",
                command=lambda c=cid: self._sort_by(c),
                anchor="w")
            anchor = "center" if cid in ("chk","score") else "w"
            stretch = cid == "nom"   # seul l'intitulé s'étire
            self.tree.column(cid,
                              width=width,
                              minwidth=max(30, width//2),
                              stretch=stretch,
                              anchor=anchor)

        # Tags couleur
        self.tree.tag_configure("sc_100", background=SC_100_BG, foreground=SC_100_FG)
        self.tree.tag_configure("sc_70",  background=SC_70_BG,  foreground=SC_70_FG)
        self.tree.tag_configure("sc_50",  background=SC_50_BG,  foreground=SC_50_FG)
        self.tree.tag_configure("sc_0",   background=SC_0_BG,   foreground=SC_0_FG)
        self.tree.tag_configure("odd",    background=SC_ODD_BG)
        self.tree.tag_configure("even",   background=C_WHITE)

        self.tree.pack(fill=tk.BOTH, expand=True)
        self.tree.bind("<ButtonRelease-1>", self._on_click)

        # ── LIGNE DE FILTRES PAR COLONNE ──────────────
        # Placée dans un frame séparé SOUS la table (layout plus simple et fiable)
        filter_bar = tk.Frame(card, bg=C_BG)
        filter_bar.pack(fill=tk.X)
        tk.Frame(filter_bar, bg=C_BORDER, height=1).pack(fill=tk.X)

        filter_inner = tk.Frame(filter_bar, bg=C_BG)
        filter_inner.pack(fill=tk.X, padx=0, pady=4)

        tk.Label(filter_inner, text=" ▼ Filtres par colonne :",
                 bg=C_BG, fg=C_TEXT2,
                 font=("Segoe UI", 8, "bold")).pack(side=tk.LEFT, padx=(8,4))

        self._col_filters = {}
        scroll_area = tk.Frame(filter_inner, bg=C_BG)
        scroll_area.pack(side=tk.LEFT, fill=tk.X, expand=True)

        for cid, label, width, key, filtrable in COLUMNS:
            if not filtrable:
                continue
            col_frm = tk.Frame(scroll_area, bg=C_BG)
            col_frm.pack(side=tk.LEFT, padx=2)

            tk.Label(col_frm, text=label[:8] + ("…" if len(label)>8 else ""),
                     bg=C_BG, fg=C_TEXT2,
                     font=("Segoe UI", 7)).pack(anchor="w")

            var = tk.StringVar()
            var.trace_add("write", lambda *_, v=var, k=key: self._apply_filters())
            self._col_filters[key] = var

            entry = tk.Entry(col_frm, textvariable=var,
                             width=max(6, width//9),
                             bg=C_WHITE, fg=C_TEXT,
                             relief="solid", bd=1,
                             font=("Segoe UI", 8),
                             insertbackground=C_TEXT)
            entry.pack(ipady=2)

        tk.Button(filter_inner, text="✕ Effacer",
                  command=self._clear_filters,
                  bg=C_BG, fg=C_DANGER,
                  activebackground="#fee2e2",
                  font=("Segoe UI", 8), relief="flat",
                  cursor="hand2", padx=6).pack(side=tk.RIGHT, padx=8)

    # ── Barre du bas ──────────────────────────────────
