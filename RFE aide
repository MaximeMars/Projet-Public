    def btn_export_exemple(self):
        path = filedialog.asksaveasfilename(
            title="Enregistrer le modèle",
            defaultextension=".csv",
            filetypes=[("CSV (;)", "*.csv"), ("Excel", "*.xlsx")])
        if not path: return
        headers = ["Code tiers","Intitulé","Adresse","Complément","Ville","Code Postal"]
        exemple = [["CLI001","Exemple SARL","12 rue de la Paix","Bâtiment A","Paris","75001"],
                   ["CLI002","Test SAS","5 avenue Foch","","Lyon","69001"]]
        if path.lower().endswith(".xlsx"):
            if not self._ensure_openpyxl(): return
            import openpyxl as xl; from openpyxl.styles import PatternFill, Font
            wb = xl.Workbook(); ws = wb.active; ws.title = "Modèle"
            ws.append(headers)
            for c in ws[1]:
                c.font = Font(bold=True, color="FFFFFF")
                c.fill = PatternFill("solid", fgColor="2563EB")
            for r in exemple: ws.append(r)
            wb.save(path)
        else:
