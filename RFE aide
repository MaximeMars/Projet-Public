    # ── Sidebar ──────────────────────────────────────────

    # ────────────────────────────────────────────────────
    #  SIDEBAR – toggle et resize par drag
    # ────────────────────────────────────────────────────

    def _toggle_sidebar(self):
        """Réduit ou agrandit la sidebar (clic simple sur le divider)."""
        if self._sb_collapsed:
            self._sb.config(width=self._sb_width)
            self._sb.pack(side=tk.LEFT, fill=tk.Y, before=self._sb_divider)
            self._sb_toggle_btn.config(text="◀")
            self._sb_collapsed = False
        else:
            self._sb.pack_forget()
            self._sb_toggle_btn.config(text="▶")
            self._sb_collapsed = True

    def _divider_press(self, event):
        """Mémorise la position de départ du drag."""
        self._drag_x_start = event.x_root
        self._drag_w_start = self._sb_width
        self._drag_active  = False   # devient True si on bouge réellement

    def _divider_drag(self, event):
        """Redimensionne la sidebar pendant le glissement."""
        delta = event.x_root - self._drag_x_start
        if abs(delta) < 3 and not self._drag_active:
            return   # ignorer les micro-mouvements (distingue clic d'un drag)
        self._drag_active = True

        new_w = max(self.SB_WIDTH_MIN,
                    min(self.SB_WIDTH_MAX, self._drag_w_start + delta))
        self._sb_width = new_w

        if self._sb_collapsed:
            # Réouvrir la sidebar si on tire vers la droite
            if new_w > self.SB_WIDTH_MIN:
                self._sb.config(width=new_w)
                self._sb.pack(side=tk.LEFT, fill=tk.Y, before=self._sb_divider)
                self._sb_collapsed = False
                self._sb_toggle_btn.config(text="◀")
        else:
            self._sb.config(width=new_w)
            # Réduire automatiquement si on tire trop à gauche
            if new_w <= self.SB_WIDTH_MIN:
                self._sb.pack_forget()
                self._sb_collapsed = True
                self._sb_toggle_btn.config(text="▶")

    def _divider_release(self, event):
        """Si le bouton est relâché sans avoir vraiment bougé → toggle."""
        if not self._drag_active:
            self._toggle_sidebar()
        self._drag_active = False

