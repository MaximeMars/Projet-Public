    def _copy(self, text: str):
        self.clipboard_clear()
        self.clipboard_append(str(text))

    # ── Menu contextuel ───────────────────────────────────────────────────────
    def _ctx_menu(self, event):
        region = self._tree.identify_region(event.x, event.y)
        if region == "heading":
            cidx = int(self._tree.identify_column(event.x).replace("#", "")) - 1
            if 0 <= cidx < len(ALL_COL_LABELS):
                self._open_col_filter(ALL_COL_LABELS[cidx], event.x_root, event.y_root)
            return

        if region != "cell":
            return
        iid    = self._tree.identify_row(event.y)
        col_id = self._tree.identify_column(event.x)
        if not (iid and col_id):
            return
        cidx    = int(col_id.replace("#", "")) - 1
        val     = self._tree.item(iid, "values")[cidx]
        col_lbl = ALL_COL_LABELS[cidx]
        idx     = int(iid)

        menu = tk.Menu(self, tearoff=0, bg=CARD, fg=TEXT,
                       activebackground=ACCENT_L, activeforeground=ACCENT,
                       font=("Segoe UI", 9))
        menu.add_command(label=f"Copier  «{str(val)[:40]}»",
                         command=lambda: self._copy(val))
        menu.add_separator()
        menu.add_command(label=f"Filtrer sur «{col_lbl}»",
                         command=lambda: self._open_col_filter(
                             col_lbl, event.x_root, event.y_root))
        if (self.results[idx] or {}).get("status") == "suggestion":
            menu.add_separator()
            def _do_open_sugg(i=idx):
                self._set_sugg_guard()
                self._open_suggestions(i)
            menu.add_command(label="🔍  Voir les suggestions",
                             command=_do_open_sugg)
        menu.add_separator()
        menu.add_command(label="Détail complet",
                         command=lambda i=idx: self._show_detail(i))
        menu.post(event.x_root, event.y_root)

