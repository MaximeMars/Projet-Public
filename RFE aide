            messagebox.showerror("Erreur", f"Lancez manuellement : pip install {pkg}")

    def _connect_db(self):
        try:
            import importlib
            mod = importlib.import_module("pyodbc")
        except ImportError:
            return False, "pyodbc non disponible."
        cfg = self.db_cfg
        drivers = [d for d in mod.drivers() if "SQL Server" in d]
        preferred = [d for d in drivers if any(v in d for v in ("17","18","19"))]
        driver = (preferred or drivers or ["SQL Server"])[0] if drivers else "SQL Server"
        cs = (f"DRIVER={{{driver}}};SERVER={cfg['server']};"
              f"DATABASE={cfg['database']};" +
              ("Trusted_Connection=yes;" if cfg["win_auth"] else
               f"UID={cfg['username']};PWD={cfg['password']};"))
        try:
            self.db_conn = mod.connect(cs, timeout=15)
            return True, "OK"
        except Exception as e:
            return False, str(e)

    def _load_from_db(self):
        if not self.db_conn: return
        try:
            cursor = self.db_conn.cursor()
            cursor.execute("""
                SELECT CT_Num, CT_Intitule, CT_Adresse, CT_Complement,
                       CT_Ville, CT_CodePostal, CT_Siren, CT_NumPaysTVA
                FROM F_COMPTET ORDER BY CT_Intitule""")
            self.data = []
            for row in cursor.fetchall():
                self.data.append(make_record(
                    code_sage=str(row[0] or "").strip(),
                    intitule=str(row[1] or "").strip(),
                    adresse=str(row[2] or "").strip(),
                    complement=str(row[3] or "").strip(),
                    ville=str(row[4] or "").strip(),
                    code_postal=str(row[5] or "").strip(),
                    siren_base=str(row[6] or "").strip(),
                    tva_base=str(row[7] or "").strip()))
            self._update_conn_status()
            self.refresh_table()
        except Exception as e:
            messagebox.showerror("Erreur SQL", str(e))

