class SbBtn(tk.Frame):
    def __init__(self, parent, icon, label, cmd):
        super().__init__(parent, bg=SB_BG, cursor="hand2")
        self._cmd = cmd

        inner = tk.Frame(self, bg=SB_BG)
        inner.pack(fill=tk.X, padx=10, pady=5)

        lbl_icon = tk.Label(inner, text=icon, bg=SB_BG, fg=SB_TEXT,
                             font=(FONT_UI, 14), width=2, anchor="center")
        lbl_icon.pack(side=tk.LEFT, padx=(0,8))

        lbl_txt = tk.Label(inner, text=label, bg=SB_BG, fg=SB_TEXT,
                            font=(FONT_UI, 12), anchor="w")
        lbl_txt.pack(side=tk.LEFT, fill=tk.X)

        self._widgets = [self, inner, lbl_icon, lbl_txt]
        for w in self._widgets:
            w.bind("<Button-1>",  lambda e: self._cmd())
            w.bind("<Enter>",     self._enter)
            w.bind("<Leave>",     self._leave)

    def _enter(self, e):
        for w in self._widgets:
            try: w.config(bg=SB_HOVER)
            except: pass
        for w in self._widgets:
            try:
                if isinstance(w, tk.Label): w.config(fg=SB_TEXT_A)
            except: pass

    def _leave(self, e):
        for w in self._widgets:
            try: w.config(bg=SB_BG)
            except: pass
        for w in self._widgets:
            try:
                if isinstance(w, tk.Label): w.config(fg=SB_TEXT)
            except: pass


