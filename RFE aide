    def _setup_col_drag(self):
        """Active le glisser-déposer des entêtes pour réordonner les colonnes."""
        self._drag_col     = None
        self._drag_src_idx = 0
        self.tree.bind("<ButtonPress-1>",   self._col_drag_start, add="+")
        self.tree.bind("<B1-Motion>",       self._col_drag_motion, add="+")
        self.tree.bind("<ButtonRelease-1>", self._col_drag_end,   add="+")

    def _get_display_cols(self):
        dc = self.tree["displaycolumns"]
        if dc in (("all",), "all"):
            return [c[0] for c in COLUMNS]
        return list(dc)

    def _col_drag_start(self, e):
        if self.tree.identify_region(e.x, e.y) != "heading":
            return
        pos = self.tree.identify_column(e.x)   # "#1", "#2", …
        if not pos: return
        idx = int(pos[1:]) - 1
        cols = self._get_display_cols()
        if idx < 0 or idx >= len(cols): return
        cid = cols[idx]
        if cid == "chk": return          # on ne déplace pas la case à cocher
        self._drag_col     = cid
        self._drag_src_idx = idx
        # Feedback visuel : ↔ devant le libellé
        orig = next((c[1] for c in COLUMNS if c[0] == cid), cid)
        self.tree.heading(cid, text=f"↔ {orig}")
        self.tree.config(cursor="fleur")

    def _col_drag_motion(self, e):
        if not self._drag_col: return
        # Surbrillance de la colonne cible
        pos = self.tree.identify_column(e.x)
        if not pos: return
        cols = self._get_display_cols()
        idx = int(pos[1:]) - 1
        if 0 <= idx < len(cols):
            tgt = cols[idx]
            for cid, label, *_ in COLUMNS:
                if cid == self._drag_col: continue
                txt = self.tree.heading(cid)["text"]
                if cid == tgt and not txt.startswith("▾ "):
                    self.tree.heading(cid, text=f"▾ {label}")
                elif cid != tgt and txt.startswith("▾ "):
                    self.tree.heading(cid, text=label)

    def _col_drag_end(self, e):
        if not self._drag_col: return
        pos    = self.tree.identify_column(e.x)
        src    = self._drag_col
        src_idx = self._drag_src_idx
        orig   = next((c[1] for c in COLUMNS if c[0] == src), src)

        # Nettoyer les visuels sur toutes les colonnes
        for cid, label, *_ in COLUMNS:
            txt = self.tree.heading(cid)["text"]
            if txt.startswith("↔ ") or txt.startswith("▾ "):
                # Conserver la flèche de tri si présente
                arrow = ""
                if self._sort_rev.get(cid) is not None:
                    arrow = " ↓" if self._sort_rev.get(cid) else ""
                self.tree.heading(cid, text=label + arrow)

        self.tree.config(cursor="")

        if pos:
            tgt_idx = int(pos[1:]) - 1
            cols = self._get_display_cols()
            if 0 <= tgt_idx < len(cols) and tgt_idx != src_idx:
                cols.pop(src_idx)
                cols.insert(tgt_idx, src)
                self.tree.configure(displaycolumns=cols)

        self._drag_col = None

