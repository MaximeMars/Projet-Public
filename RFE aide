def odbc_drivers_installed():
    """Retourne la liste des drivers ODBC SQL Server installés."""
    try:
        import importlib
        mod = importlib.import_module("pyodbc")
        return [d for d in mod.drivers() if "SQL Server" in d]
    except:
        return []


def download_and_install_odbc(version="18", progress_cb=None):
    """
    Télécharge et installe silencieusement le driver ODBC SQL Server.
    progress_cb(message: str) est appelé pour rendre compte de l'avancement.
    Retourne (True, "OK") ou (False, "raison d'erreur").
    """
    if platform.system() != "Windows":
        return False, "Installation automatique disponible sur Windows uniquement."

    name, url, args = ODBC_DRIVERS[version]
    if progress_cb: progress_cb(f"Téléchargement de {name}…")

    try:
        resp = requests.get(url, stream=True, timeout=60,
                            allow_redirects=True)
        resp.raise_for_status()
        total = int(resp.headers.get("content-length", 0))
        downloaded = 0

        tmp = tempfile.NamedTemporaryFile(delete=False, suffix=".msi")
        for chunk in resp.iter_content(chunk_size=65536):
            if chunk:
                tmp.write(chunk)
                downloaded += len(chunk)
                if total and progress_cb:
                    pct = int(downloaded / total * 100)
                    progress_cb(f"Téléchargement {pct}%…")
        tmp.close()
    except Exception as e:
        return False, f"Échec du téléchargement : {e}"

    if progress_cb: progress_cb("Installation en cours (quelques secondes)…")
    try:
        cmd = ["msiexec", "/i", tmp.name, "/quiet", "/norestart"] + args
        result = subprocess.run(cmd, timeout=120,
                                capture_output=True, text=True)
        os.unlink(tmp.name)
        if result.returncode not in (0, 3010):  # 3010 = reboot required, ok
            return False, f"msiexec code {result.returncode}: {result.stderr}"
        return True, "OK"
    except Exception as e:
        try: os.unlink(tmp.name)
        except: pass
        return False, f"Erreur installation : {e}"


