        except Exception as e:
            messagebox.showerror("Erreur import", str(e)); return
        if not records:
            messagebox.showwarning("Import", "Aucune ligne lue."); return

        if self.data:
            rep = messagebox.askyesnocancel(
                "Import — données existantes",
                f"{len(records)} enregistrements lus.\n"
                "Oui = Fusionner  |  Non = Remplacer")
            if rep is None: return
            if rep:
