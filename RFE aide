class ColFilterPopup(tk.Toplevel):
    def __init__(self, parent, col_label, all_values, current_filter, on_change):
        super().__init__(parent)
        self.overrideredirect(True)
        self.configure(bg=CARD, highlightbackground=BORDER, highlightthickness=1)
        self.attributes("-topmost", True)
        self._on_change = on_change
        self._col_label = col_label
        self._unique = sorted(set(str(v) for v in all_values if str(v).strip()))
        self._checked = {v: tk.BooleanVar(value=(v in current_filter
                                                  if current_filter is not None else True))
                         for v in self._unique}
        self._build()
        self._bind_id = parent.bind("<Button-1>", self._maybe_close, add=True)
        self.bind("<Destroy>", lambda e: self._unbind_parent(parent))

    def _unbind_parent(self, parent):
        try:
            parent.unbind("<Button-1>", self._bind_id)
        except Exception:
            pass

    def _build(self):
        tk.Frame(self, bg=ACCENT, height=3).pack(fill="x")
        hdr = tk.Frame(self, bg=CARD2)
        hdr.pack(fill="x")
        tk.Label(hdr, text=f"Filtrer : {self._col_label}", bg=CARD2, fg=TEXT,
                 font=("Segoe UI", 9, "bold"), padx=10, pady=6).pack(side="left")
        tk.Button(hdr, text="✕", bg=CARD2, fg=TEXT3, relief="flat",
                  font=("Segoe UI", 9), cursor="hand2", padx=8,
                  command=self.destroy).pack(side="right")

        sf = tk.Frame(self, bg=CARD)
        sf.pack(fill="x", padx=8, pady=(6, 2))
        self._sv = tk.StringVar()
        tk.Entry(sf, textvariable=self._sv, bg=CARD2, fg=TEXT, relief="flat",
                 font=("Segoe UI", 9), highlightbackground=BORDER,
                 highlightthickness=1).pack(fill="x", ipady=4, padx=1)
        self._sv.trace_add("write", lambda *_: self._rebuild())

        top_row = tk.Frame(self, bg=CARD)
        top_row.pack(fill="x", padx=8, pady=(4, 0))
        for lbl, cmd in [("✓ Tout", self._all), ("✗ Aucun", self._none)]:
            tk.Button(top_row, text=lbl, command=cmd, bg=CARD2, fg=TEXT2,
                      relief="flat", font=("Segoe UI", 8), cursor="hand2",
                      padx=8, pady=3).pack(side="left", padx=(0, 4))

        list_frame = tk.Frame(self, bg=CARD)
        list_frame.pack(fill="both", expand=True, padx=8, pady=4)
        canvas = tk.Canvas(list_frame, bg=CARD, highlightthickness=0, bd=0)
        vsb = ttk.Scrollbar(list_frame, orient="vertical", command=canvas.yview)
        canvas.configure(yscrollcommand=vsb.set)
        vsb.pack(side="right", fill="y")
        canvas.pack(side="left", fill="both", expand=True)
        self._inner = tk.Frame(canvas, bg=CARD)
        win = canvas.create_window((0, 0), window=self._inner, anchor="nw")
        self._inner.bind("<Configure>",
                         lambda e: canvas.configure(scrollregion=canvas.bbox("all")))
        canvas.bind("<Configure>", lambda e: canvas.itemconfig(win, width=e.width))
        self._canvas = canvas
        self._rebuild()

        bf = tk.Frame(self, bg=CARD2)
        bf.pack(fill="x")
        tk.Button(bf, text="Effacer", command=self._clear, bg=CARD2, fg=TEXT2,
                  relief="flat", font=("Segoe UI", 9), cursor="hand2",
                  pady=7, padx=12).pack(side="left")
        tk.Button(bf, text="Fermer", command=self.destroy, bg=ACCENT, fg="white",
                  relief="flat", font=("Segoe UI", 9, "bold"), cursor="hand2",
                  pady=7, padx=16).pack(side="right", padx=4, pady=4)

    def _rebuild(self):
        for w in self._inner.winfo_children():
            w.destroy()
        txt = self._sv.get().upper()
        for v in (v for v in self._unique if txt in v.upper()):
            tk.Checkbutton(self._inner, text=v, variable=self._checked[v],
                           bg=CARD, fg=TEXT, font=("Segoe UI", 9), anchor="w",
                           activebackground=CARD2, selectcolor=CARD2,
                           command=self._live).pack(fill="x", padx=4, pady=1)
        self._canvas.update_idletasks()
        self._canvas.configure(scrollregion=self._canvas.bbox("all"))

    def _live(self):
        sel = {v for v, var in self._checked.items() if var.get()}
        self._on_change(self._col_label,
                        None if len(sel) == len(self._unique) else sel)

    def _all(self):
        for var in self._checked.values():
            var.set(True)
        self._on_change(self._col_label, None)
        self._rebuild()

    def _none(self):
        for var in self._checked.values():
            var.set(False)
        self._on_change(self._col_label, set())
        self._rebuild()

    def _clear(self):
        self._on_change(self._col_label, None)
        self.destroy()

    def _maybe_close(self, event):
        try:
            if not str(event.widget).startswith(str(self)):
                self.after(250, self._safe_destroy)
        except Exception:
            pass

    def _safe_destroy(self):
        try:
            if self.winfo_exists():
                self.destroy()
        except Exception:
            pass


