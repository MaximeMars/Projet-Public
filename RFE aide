def calculate_tva_fr(siren):
    s = siren.strip()
    if not s or not s.isdigit() or len(s) != 9: return ""
    key = (12 + 3 * (int(s) % 97)) % 97
    return f"FR{str(key).zfill(2)}{s}"

def clean_cp(s):
    """Extrait un code postal à 5 chiffres depuis une chaîne quelconque."""
    import re as _re
    m = _re.search(r'\b(\d{5})\b', s)
    return m.group(1) if m else ""

def clean_ville(s):
    """Supprime 'cedex', numéros d'arrondissement parasites, etc."""
    import re as _re
    s = _re.sub(r'(?i)\bcedex\b\s*\d*', '', s)
    s = _re.sub(r'\s+', ' ', s)
    return s.strip()

def normalize_str(s):
    s = s.upper().strip()
    s = unicodedata.normalize("NFD", s)
    s = "".join(c for c in s if unicodedata.category(c) != "Mn")
    for ch in [",",".","-","'",'"',"(",")"]: s = s.replace(ch," ")
    return " ".join(s.split())

def addr_similarity(a1, a2):
    STOP = {"RUE","AV","AVE","AVENUE","BD","BOULEVARD","LE","LA","LES",
            "DE","DU","DES","EN","ET","A","AU","IMPASSE","ALLEE"}
    w1 = set(normalize_str(a1).split()) - STOP or set(normalize_str(a1).split())
    w2 = set(normalize_str(a2).split()) - STOP or set(normalize_str(a2).split())
    if not w1 or not w2: return 0.0
    return len(w1 & w2) / max(len(w1), len(w2))

