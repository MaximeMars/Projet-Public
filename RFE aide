    def uncheck_all(self):
        rows = self._get_visible()
        for rec in rows: rec["checked"] = False
        self.refresh_table()
        self._status(f"Décochés : {len(rows)} tiers visibles")

    def _sort_by(self, col_id):
        if col_id == "chk": return
        key = next((c[3] for c in COLUMNS if c[0] == col_id), col_id)
        rev = self._sort_rev.get(col_id, False)
        self.data.sort(key=lambda r: str(r.get(key, "")).lower(), reverse=rev)
        self._sort_rev[col_id] = not rev
        for cid, label, *_ in COLUMNS:
            try:
                arrow = (" ↑" if not rev else " ↓") if cid == col_id else ""
                self.tree.heading(cid, text=label + arrow)
            except Exception:
                pass
        self.refresh_table()

    def _clear_filters(self):
        for var in self._col_filters.values(): var.set("")
        self.var_gfilter.set("")
        self._gf_entry.delete(0, tk.END)
        self._gf_entry.insert(0, self._gf_placeholder)
        self._gf_entry.config(fg=C_TEXT2)
        self.refresh_table()

