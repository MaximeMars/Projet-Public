    def btn_export_resultats(self):
        if not self.data:
            messagebox.showwarning("Export", "Aucune donnée à exporter."); return

        checked = [r for r in self.data if r.get("checked")]
        if checked:
            rep = messagebox.askyesnocancel(
                "Exporter",
                str(len(checked)) + " tiers cochés  /  " + str(len(self.data)) + " total.\n\n"
                "Oui = exporter uniquement les cochés\n"
                "Non = exporter tous les tiers\n"
                "Annuler = abandonner")
            if rep is None: return
            export_data = checked if rep else self.data
        else:
            if not messagebox.askyesno("Exporter",
                    "Aucun tiers coché. Exporter les " + str(len(self.data)) + " tiers ?"):
                return
            export_data = self.data

        n_total  = len(export_data)
        n_sirene = sum(1 for r in export_data if r.get("siren_trouve") and r["siren_trouve"] not in ("","non trouvé","erreur","erreur réseau","timeout"))
        n_tva    = sum(1 for r in export_data if r.get("tva_calcule","").startswith("FR"))
        n_ctrl   = sum(1 for r in export_data if r.get("tva_statut") not in ("","Indéterminé"))

        if not messagebox.askyesno("Confirmer",
                str(n_total) + " tiers  —  " + str(n_sirene) + " SIREN  |  " + str(n_tva) + " TVA  |  " + str(n_ctrl) + " contrôlés\n\nContinuer ?"):
            return
        path = filedialog.asksaveasfilename(
            title="Exporter les résultats",
            defaultextension=".xlsx",
            filetypes=[("Excel", "*.xlsx"), ("CSV (;)", "*.csv")])
        if not path: return

        # ── Colonnes exportées — TOUTES les informations disponibles ──
        EXPORT = [
            # (entête,              clé data)
            ("Code Tiers",          "code_sage"),
            ("Intitulé",            "intitule"),
            # ── Données source ──
            ("Adresse (source)",    "adresse"),
            ("Complément (source)", "complement"),
            ("Ville (source)",      "ville"),
            ("CP (source)",         "code_postal"),
            ("SIRET base",          "siren_base"),
            ("TVA base",            "tva_base"),
            # ── Résultats SIRENE ──
            ("SIREN trouvé",        "siren_trouve"),
            ("SIRET trouvé",        "siret_trouve"),
            ("Score SIRENE",        "score"),
            ("Adresse trouvée",     "adresse_trouvee"),
            ("CP trouvé",           "cp_trouve"),
            ("Ville trouvée",       "ville_trouvee"),
            # ── TVA ──
            ("TVA calculé",         "tva_calcule"),
            ("Ctrl TVA (VIES)",     "tva_statut"),
            # ── Suggestions ──
            ("Suggestions",         "suggestions_txt"),
        ]
        HDRS = [e[0] for e in EXPORT]
        KEYS = [e[1] for e in EXPORT]

        rows = [[r.get(k, "") for k in KEYS] for r in export_data]

        if path.lower().endswith(".xlsx"):
            if not self._ensure_openpyxl(): return
            import openpyxl as xl
            from openpyxl.styles import PatternFill, Font, Alignment, Border, Side
            from openpyxl.utils import get_column_letter

            wb = xl.Workbook()
            ws = wb.active
            ws.title = "Résultats SIRENE"

            # ── En-têtes ──────────────────────────────────
            HDR_FILL   = PatternFill("solid", fgColor="1A2332")
            HDR_FONT   = Font(bold=True, color="FFFFFF", name="Calibri", size=10)
            HDR_ALIGN  = Alignment(horizontal="center", vertical="center", wrap_text=True)
            THIN       = Side(style="thin", color="CCCCCC")
            CELL_BORDER = Border(left=THIN, right=THIN, top=THIN, bottom=THIN)

            ws.append(HDRS)
            ws.row_dimensions[1].height = 32
            for col_idx, cell in enumerate(ws[1], 1):
                cell.fill      = HDR_FILL
                cell.font      = HDR_FONT
                cell.alignment = HDR_ALIGN
                cell.border    = CELL_BORDER

            # ── Données + coloration par score / statut TVA ──
            # Score → couleur de fond ligne
            SCORE_FILL = {
                "100": PatternFill("solid", fgColor="DCFCE7"),   # vert
                "70":  PatternFill("solid", fgColor="FEF9C3"),   # jaune
                "50":  PatternFill("solid", fgColor="FFEDD5"),   # orange pâle
                "0":   PatternFill("solid", fgColor="FEE2E2"),   # rouge
            }
            # Statut TVA → couleur cellule colonne "Ctrl TVA"
            TVA_FILLS = {
                "OK":         PatternFill("solid", fgColor="DCFCE7"),
                "OK (SIRENE)":PatternFill("solid", fgColor="D1FAE5"),
                "OK (VIES+SIRENE)": PatternFill("solid", fgColor="D1FAE5"),
                "Non trouvé": PatternFill("solid", fgColor="FEE2E2"),
                "Indéterminé":PatternFill("solid", fgColor="FEF9C3"),
            }
            TVA_COL_IDX = KEYS.index("tva_statut") + 1   # 1-based

            DATA_FONT  = Font(name="Calibri", size=10)
            DATA_ALIGN = Alignment(vertical="center", wrap_text=False)
            ODD_FILL   = PatternFill("solid", fgColor="F8FAFC")
            EVEN_FILL  = PatternFill("solid", fgColor="FFFFFF")

            for row_idx, (row_data, rec) in enumerate(zip(rows, export_data), 2):
                ws.append(row_data)
                ws.row_dimensions[row_idx].height = 18
                sc  = rec.get("score", "")
                alt = ODD_FILL if row_idx % 2 else EVEN_FILL
                row_fill = SCORE_FILL.get(sc, alt)

                for col_idx, cell in enumerate(ws[row_idx], 1):
                    cell.font      = DATA_FONT
                    cell.alignment = DATA_ALIGN
                    cell.border    = CELL_BORDER
                    if col_idx == TVA_COL_IDX:
                        # Cellule TVA colorée indépendamment
                        tva_st = str(cell.value or "")
                        # Chercher la correspondance (commence par)
                        tva_fill = next(
                            (f for k, f in TVA_FILLS.items() if tva_st.startswith(k)),
                            row_fill)
                        cell.fill = tva_fill
                        cell.font = Font(name="Calibri", size=10, bold=True)
                    else:
                        cell.fill = row_fill

            # ── Largeurs colonnes ──────────────────────────
            MIN_W = {"Score SIRENE": 8, "CP (source)": 8, "CP trouvé": 8,
                     "Ctrl TVA (VIES)": 14}
            for col in ws.iter_cols():
                hdr_txt = str(col[0].value or "")
                max_len = max((len(str(c.value or "")) for c in col), default=8)
                auto_w  = min(max_len + 2, 42)
                ws.column_dimensions[col[0].column_letter].width = max(
                    auto_w, MIN_W.get(hdr_txt, 10))

            # ── Volet figé (ligne d'en-tête + col Code Sage) ──
            ws.freeze_panes = "C2"

            # ── Filtre automatique ─────────────────────────
            ws.auto_filter.ref = ws.dimensions

            wb.save(path)

        else:
            with open(path, "w", newline="", encoding="utf-8-sig") as f:
                w = csv.writer(f, delimiter=";")
                w.writerow(HDRS)
                w.writerows(rows)

        messagebox.showinfo("Export", f"{len(export_data)} tiers exportés.\n{path}")

