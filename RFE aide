def install_package(pkg):
    try:
        subprocess.check_call([sys.executable, "-m", "pip", "install", pkg],
                              stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        return True
    except: return False

def calculate_tva_fr(siren):
    s = siren.strip()
    if not s or not s.isdigit() or len(s) != 9: return ""
    key = (12 + 3 * (int(s) % 97)) % 97
    return f"FR{str(key).zfill(2)}{s}"

def normalize_str(s):
    s = s.upper().strip()
    s = unicodedata.normalize("NFD", s)
    s = "".join(c for c in s if unicodedata.category(c) != "Mn")
    for ch in [",",".","-","'",'"',"(",")"]: s = s.replace(ch," ")
    return " ".join(s.split())

def addr_similarity(a1, a2):
    STOP = {"RUE","AV","AVE","AVENUE","BD","BOULEVARD","LE","LA","LES","DE","DU","DES","EN","ET","A","AU"}
    w1 = set(normalize_str(a1).split()) - STOP or set(normalize_str(a1).split())
    w2 = set(normalize_str(a2).split()) - STOP or set(normalize_str(a2).split())
    if not w1 or not w2: return 0.0
    return len(w1 & w2) / max(len(w1), len(w2))

def make_record(**kw):
    base = dict(code_sage="", intitule="", adresse="", complement="",
                ville="", code_postal="", siren_base="", tva_base="",
                siren_trouve="", tva_calcule="", adresse_trouvee="",
                cp_trouve="", ville_trouvee="", score="", checked=False)
    base.update(kw)
    return base

def csv_row_to_record(row):
    MAP = {"code sage":"code_sage","code_sage":"code_sage",
           "intitulé":"intitule","intitule":"intitule","adresse":"adresse",
           "complément":"complement","complement":"complement","ville":"ville",
           "code postal":"code_postal","code_postal":"code_postal"}
    rec = make_record()
    for k, v in row.items():
        key = MAP.get(str(k).lower().strip())
        if key: rec[key] = str(v).strip()
    return rec


